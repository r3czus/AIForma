<MudPaper Class="macro-card" Elevation="0">
    @if (Day.Target is null)
    {
        <div class="macro-empty">
            <div>
                <span class="card-kicker">Dzienne paliwo</span>
                <h2>Ustal swój punkt odniesienia</h2>
                <p>Dodaj cel kalorii i makro, żeby widzieć tempo dnia zamiast samych liczb.</p>
            </div>
            <MudButton Href="/food" Variant="Variant.Outlined">Ustaw dzienny cel</MudButton>
        </div>
    }
    else
    {
        <div class="macro-heading">
            <div><span class="card-kicker">Dzienne paliwo</span><h2>Bilans energii</h2></div>
            <a href="/food">Otwórz dziennik</a>
        </div>
        <div class="macro-overview energy-balance-hero">
            <div class="calorie-ring" style="@($"--progress: {Percent(Day.Consumed.CaloriesKcal, Day.Target.CaloriesKcal)}%")" aria-label="@EnergyRingLabel">
                <div>
                    <span>@RemainingCaption</span>
                    <strong>@Math.Abs(Day.Remaining!.CaloriesKcal).ToString("0")</strong>
                    <small>kcal</small>
                </div>
            </div>
            <div class="calorie-score energy-balance-copy">
                <span>@EnergyHeadline</span>
                <strong>@Math.Abs(Day.Remaining.CaloriesKcal).ToString("0") <small>kcal</small></strong>
                <p>Zjedzone <b>@Day.Consumed.CaloriesKcal.ToString("0") kcal</b> z dzisiejszego limitu <b>@Day.Target.CaloriesKcal.ToString("0") kcal</b>.</p>
                <span class="calorie-percent">@CaloriePercent% celu</span>
            </div>
        </div>
        @if (Day.BaseTarget is not null)
        {
            <div class="calorie-target-breakdown">
                <div class="target-breakdown-card"><span>Cel bazowy</span><strong>@Day.BaseTarget.CaloriesKcal.ToString("0")</strong><small>kcal</small></div>
                <div class="target-breakdown-card bonus @(Day.TrainingBonusCalories > 0 ? "earned" : null)"><span>Bonus z treningu</span><strong>+@Day.TrainingBonusCalories.ToString("0")</strong><small>kcal</small></div>
                <div class="target-breakdown-card total"><span>Dzisiejszy limit</span><strong>@Day.Target.CaloriesKcal.ToString("0")</strong><small>kcal</small></div>
            </div>
        }
        <div class="macro-grid">
            <div class="protein" style="@($"--progress: {Percent(Day.Consumed.ProteinG, Day.Target.ProteinG)}%")">
                <header><span>Białko</span><small>cel @Day.Target.ProteinG.ToString("0.#") g</small></header>
                <div class="macro-values"><div><span>Zjedzone</span><strong>@Day.Consumed.ProteinG.ToString("0.#") g</strong></div><div><span>@RemainingLabel(Day.Remaining.ProteinG)</span><strong class="@RemainingClass(Day.Remaining.ProteinG)">@Math.Abs(Day.Remaining.ProteinG).ToString("0.#") g</strong></div></div><i></i>
            </div>
            <div class="fat" style="@($"--progress: {Percent(Day.Consumed.FatG, Day.Target.FatG)}%")">
                <header><span>Tłuszcze</span><small>cel @Day.Target.FatG.ToString("0.#") g</small></header>
                <div class="macro-values"><div><span>Zjedzone</span><strong>@Day.Consumed.FatG.ToString("0.#") g</strong></div><div><span>@RemainingLabel(Day.Remaining.FatG)</span><strong class="@RemainingClass(Day.Remaining.FatG)">@Math.Abs(Day.Remaining.FatG).ToString("0.#") g</strong></div></div><i></i>
            </div>
            <div class="carbs" style="@($"--progress: {Percent(Day.Consumed.CarbohydratesG, Day.Target.CarbohydratesG)}%")">
                <header><span>Węglowodany</span><small>cel @Day.Target.CarbohydratesG.ToString("0.#") g</small></header>
                <div class="macro-values"><div><span>Zjedzone</span><strong>@Day.Consumed.CarbohydratesG.ToString("0.#") g</strong></div><div><span>@RemainingLabel(Day.Remaining.CarbohydratesG)</span><strong class="@RemainingClass(Day.Remaining.CarbohydratesG)">@Math.Abs(Day.Remaining.CarbohydratesG).ToString("0.#") g</strong></div></div><i></i>
            </div>
        </div>
    }
</MudPaper>

@code {
    [Parameter, EditorRequired] public NutritionDayResponse Day { get; set; } = null!;

    private string RemainingCaption => Day.Remaining!.CaloriesKcal < 0 ? "ponad cel" : "do zjedzenia";
    private string EnergyHeadline => Day.Remaining!.CaloriesKcal < 0 ? "Ponad dzisiejszy limit" : "Możesz jeszcze zjeść";
    private string EnergyRingLabel => Day.Remaining!.CaloriesKcal < 0
        ? $"Cel przekroczony o {Math.Abs(Day.Remaining.CaloriesKcal):0} kilokalorii"
        : $"Pozostało {Day.Remaining.CaloriesKcal:0} z celu {Day.Target!.CaloriesKcal:0} kilokalorii";
    private int CaloriePercent => Day.Target!.CaloriesKcal <= 0 ? 0 : (int)Math.Round(Day.Consumed.CaloriesKcal / Day.Target.CaloriesKcal * 100);
    private static string RemainingLabel(decimal value) => value < 0 ? "Ponad cel" : "Zostało";
    private static string RemainingClass(decimal value) => value < 0 ? "over" : "remaining";

    private static int Percent(decimal value, decimal target) => target <= 0
        ? 0
        : Math.Clamp((int)Math.Round(value / target * 100), 0, 100);
}
