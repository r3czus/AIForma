<MudPaper Class="macro-card" Elevation="0">
    @if (Day.Target is null)
    {
        <div class="macro-empty">
            <div>
                <span class="card-kicker">Dzienne paliwo</span>
                <h2>Ustal swój punkt odniesienia</h2>
                <p>Dodaj cel kalorii i makro, żeby widzieć tempo dnia zamiast samych liczb.</p>
            </div>
            <MudButton Href="/food" Variant="Variant.Outlined">Ustaw dzienny cel</MudButton>
        </div>
    }
    else
    {
        <div class="macro-heading">
            <div><span class="card-kicker">Dzienne paliwo</span><h2>Bilans energii</h2></div>
            <a href="/food">Otwórz dziennik</a>
        </div>
        <div class="macro-overview">
            <div class="calorie-ring" style="@($"--progress: {Percent(Day.Consumed.CaloriesKcal, Day.Target.CaloriesKcal)}%")" aria-label="@EnergyRingLabel">
                <div>
                    <span>@RemainingCaption</span>
                    <strong>@Math.Abs(Day.Remaining!.CaloriesKcal).ToString("0")</strong>
                    <small>kcal</small>
                </div>
            </div>
            <div class="calorie-score">
                <span>Spożyte dzisiaj</span>
                <strong>@Day.Consumed.CaloriesKcal.ToString("0")</strong>
                <small>cel @Day.Target.CaloriesKcal.ToString("0") kcal</small>
                <span class="calorie-percent">@CaloriePercent% celu</span>
            </div>
        </div>
        <div class="macro-grid">
            <div class="protein" style="@($"--progress: {Percent(Day.Consumed.ProteinG, Day.Target.ProteinG)}%")"><span>Białko</span><strong>@Day.Consumed.ProteinG.ToString("0.#") g</strong><small>z @Day.Target.ProteinG.ToString("0.#") g</small><i></i></div>
            <div class="fat" style="@($"--progress: {Percent(Day.Consumed.FatG, Day.Target.FatG)}%")"><span>Tłuszcze</span><strong>@Day.Consumed.FatG.ToString("0.#") g</strong><small>z @Day.Target.FatG.ToString("0.#") g</small><i></i></div>
            <div class="carbs" style="@($"--progress: {Percent(Day.Consumed.CarbohydratesG, Day.Target.CarbohydratesG)}%")"><span>Węglowodany</span><strong>@Day.Consumed.CarbohydratesG.ToString("0.#") g</strong><small>z @Day.Target.CarbohydratesG.ToString("0.#") g</small><i></i></div>
        </div>
    }
</MudPaper>

@code {
    [Parameter, EditorRequired] public NutritionDayResponse Day { get; set; } = null!;

    private string RemainingCaption => Day.Remaining!.CaloriesKcal < 0 ? "ponad cel" : "do zjedzenia";
    private string EnergyRingLabel => Day.Remaining!.CaloriesKcal < 0
        ? $"Cel przekroczony o {Math.Abs(Day.Remaining.CaloriesKcal):0} kilokalorii"
        : $"Pozostało {Day.Remaining.CaloriesKcal:0} z celu {Day.Target!.CaloriesKcal:0} kilokalorii";
    private int CaloriePercent => Day.Target!.CaloriesKcal <= 0 ? 0 : (int)Math.Round(Day.Consumed.CaloriesKcal / Day.Target.CaloriesKcal * 100);

    private static int Percent(decimal value, decimal target) => target <= 0
        ? 0
        : Math.Clamp((int)Math.Round(value / target * 100), 0, 100);
}
