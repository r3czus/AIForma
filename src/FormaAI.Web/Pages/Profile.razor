@page "/profile"
@inject AccountClient Account
@inject NutritionClient Nutrition
@inject ProgressClient ProgressApi
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Profil · FormaAI</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="content-wrap module-page profile-page">
    @if (_loading)
    {
        <div class="page-loader compact"><MudProgressCircular Indeterminate="true" Color="Color.Primary" /><span>Wczytuję profil</span></div>
    }
    else
    {
        <header class="module-heading profile-heading">
            <div>
                <span class="page-kicker">Twoje ustawienia</span>
                <MudText Typo="Typo.h4">Profil</MudText>
                <p>Cel i zasady liczenia w jednym miejscu.</p>
            </div>
        </header>

        <section class="profile-summary">
            <span class="profile-avatar">@Initial</span>
            <div><strong>@_profile!.Email</strong><span>@GoalName</span></div>
            <small>@(_targetCalories is null ? "Uzupełnij dane i wylicz cel" : $"{_targetCalories:0} kcal dziennie")</small>
        </section>

        <MudTabs Class="module-tabs profile-tabs" PanelClass="profile-panel">
            <MudTabPanel Text="Cel i kalorie">
                <MudPaper Class="goal-wizard" Elevation="0">
                    <div class="goal-wizard-progress">
                        <div><span>Cel żywieniowy</span><strong>Krok @_goalStep / 9</strong></div>
                        <div class="goal-progress-track" aria-hidden="true"><i style="@($"width: {GoalProgress}%")"></i></div>
                    </div>

                    @switch (_goalStep)
                    {
                        case 1:
                            <section class="goal-step">
                                <div class="profile-section-heading"><span class="card-kicker">Kierunek</span><h2>Jaki jest Twój cel?</h2><p>Wybierz kierunek, a dopasujemy dzienne zapotrzebowanie.</p></div>
                                <div class="goal-choice-grid goal-choice-grid-three">
                                    <button type="button" class="@ChoiceClass(_goal == BodyGoal.Reduction)" aria-pressed="@(_goal == BodyGoal.Reduction)" @onclick="() => _goal = BodyGoal.Reduction"><MudIcon Icon="@Icons.Material.Outlined.TrendingDown" /><strong>Redukcja</strong><span>Chcę zmniejszyć masę ciała</span></button>
                                    <button type="button" class="@ChoiceClass(_goal == BodyGoal.Maintenance)" aria-pressed="@(_goal == BodyGoal.Maintenance)" @onclick="() => _goal = BodyGoal.Maintenance"><MudIcon Icon="@Icons.Material.Outlined.Balance" /><strong>Utrzymanie</strong><span>Chcę utrzymać obecną wagę</span></button>
                                    <button type="button" class="@ChoiceClass(_goal == BodyGoal.MuscleGain)" aria-pressed="@(_goal == BodyGoal.MuscleGain)" @onclick="() => _goal = BodyGoal.MuscleGain"><MudIcon Icon="@Icons.Material.Outlined.FitnessCenter" /><strong>Budowanie masy</strong><span>Chcę zwiększyć masę ciała</span></button>
                                </div>
                            </section>
                            break;
                        case 2:
                            <section class="goal-step">
                                <div class="profile-section-heading"><span class="card-kicker">Podstawowe dane</span><h2>Jaka jest Twoja płeć?</h2><p>Ta informacja jest potrzebna do wzoru podstawowej przemiany materii.</p></div>
                                <div class="goal-choice-grid">
                                    <button type="button" class="@ChoiceClass(_sex == BiologicalSex.Male)" aria-pressed="@(_sex == BiologicalSex.Male)" @onclick="() => _sex = BiologicalSex.Male"><MudIcon Icon="@Icons.Material.Outlined.Male" /><strong>Mężczyzna</strong></button>
                                    <button type="button" class="@ChoiceClass(_sex == BiologicalSex.Female)" aria-pressed="@(_sex == BiologicalSex.Female)" @onclick="() => _sex = BiologicalSex.Female"><MudIcon Icon="@Icons.Material.Outlined.Female" /><strong>Kobieta</strong></button>
                                </div>
                            </section>
                            break;
                        case 3:
                            <section class="goal-step goal-step-narrow">
                                <div class="profile-section-heading"><span class="card-kicker">Metabolizm</span><h2>Twoja data urodzenia</h2><p>Wiek wpływa na podstawowe zapotrzebowanie energetyczne.</p></div>
                                <MudDatePicker @bind-Date="_birthDate" Label="Data urodzenia" MaxDate="DateTime.Today" />
                            </section>
                            break;
                        case 4:
                            <section class="goal-step goal-step-narrow">
                                <div class="profile-section-heading"><span class="card-kicker">Parametry ciała</span><h2>Jaki masz wzrost?</h2><p>Podaj wzrost w centymetrach.</p></div>
                                <label class="mobile-number-field"><span>Wzrost (cm)</span><input type="text" inputmode="decimal" autocomplete="off" @bind="_heightInput" @bind:event="oninput" placeholder="np. 180" /></label>
                            </section>
                            break;
                        case 5:
                            <section class="goal-step goal-step-narrow">
                                <div class="profile-section-heading"><span class="card-kicker">Punkt wyjścia</span><h2>Jaka jest Twoja aktualna masa?</h2><p>Najlepiej podaj pomiar wykonany rano.</p></div>
                                <label class="mobile-number-field"><span>Obecna masa (kg)</span><input type="text" inputmode="decimal" autocomplete="off" @bind="_currentWeightInput" @bind:event="oninput" placeholder="np. 82,5" /></label>
                            </section>
                            break;
                        case 6:
                            <section class="goal-step goal-step-narrow">
                                <div class="profile-section-heading"><span class="card-kicker">Meta</span><h2>Jaka jest Twoja docelowa masa?</h2><p>@TargetWeightHint</p></div>
                                 <label class="mobile-number-field"><span>Masa docelowa (kg)</span><input type="text" inputmode="decimal" autocomplete="off" @bind="_targetWeightInput" @bind:event="oninput" placeholder="np. 78" /></label>
                                @if (_goal != BodyGoal.Maintenance)
                                {
                                    <MudNumericField @bind-Value="_weeklyWeightChangeKg" Label="Zmiana masy na tydzień (kg)" Min="0.05m" Max="1.5m" Step="0.05m" HelperText="Ta wartość bezpośrednio zmienia dzienny bilans kalorii." Class="mt-4" />
                                }
                                @if (_currentWeightKg is not null && _targetWeightKg is not null)
                                {
                                    <span class="goal-weight-difference">@WeightDifference</span>
                                }
                            </section>
                            break;
                        case 7:
                            <section class="goal-step">
                                <div class="profile-section-heading"><span class="card-kicker">Aktywność w pracy</span><h2>Jak wygląda Twój zwykły dzień?</h2><p>Nie wliczaj tu treningów. Chodzi o pracę, kroki i codzienny ruch.</p></div>
                                <div class="goal-choice-grid activity-choice-grid">
                                    <button type="button" class="@ChoiceClass(_workActivity == ActivityLevel.Low)" aria-pressed="@(_workActivity == ActivityLevel.Low)" @onclick="() => _workActivity = ActivityLevel.Low"><strong>Siedząca</strong><span>Większość dnia przy biurku</span></button>
                                    <button type="button" class="@ChoiceClass(_workActivity == ActivityLevel.Light)" aria-pressed="@(_workActivity == ActivityLevel.Light)" @onclick="() => _workActivity = ActivityLevel.Light"><strong>Lekko aktywna</strong><span>Spacery i częste wstawanie</span></button>
                                    <button type="button" class="@ChoiceClass(_workActivity == ActivityLevel.Moderate)" aria-pressed="@(_workActivity == ActivityLevel.Moderate)" @onclick="() => _workActivity = ActivityLevel.Moderate"><strong>Aktywna</strong><span>Dużo chodzenia w pracy</span></button>
                                    <button type="button" class="@ChoiceClass(_workActivity == ActivityLevel.High)" aria-pressed="@(_workActivity == ActivityLevel.High)" @onclick="() => _workActivity = ActivityLevel.High"><strong>Fizyczna</strong><span>Ciężka praca lub ruch cały dzień</span></button>
                                </div>
                            </section>
                            break;
                        case 8:
                            <section class="goal-step">
                                <div class="profile-section-heading"><span class="card-kicker">Aktywność treningowa</span><h2>Ile wysiłku dają Ci treningi?</h2><p>Ten wybór jest liczony osobno od pracy i codziennego ruchu.</p></div>
                                <div class="goal-choice-grid activity-choice-grid">
                                    <button type="button" class="@ChoiceClass(_trainingActivity == ActivityLevel.Low)" aria-pressed="@(_trainingActivity == ActivityLevel.Low)" @onclick="() => _trainingActivity = ActivityLevel.Low"><strong>Brak lub lekka</strong><span>0–1 spokojna sesja tygodniowo</span></button>
                                    <button type="button" class="@ChoiceClass(_trainingActivity == ActivityLevel.Light)" aria-pressed="@(_trainingActivity == ActivityLevel.Light)" @onclick="() => _trainingActivity = ActivityLevel.Light"><strong>Lekka</strong><span>2–3 krótsze sesje</span></button>
                                    <button type="button" class="@ChoiceClass(_trainingActivity == ActivityLevel.Moderate)" aria-pressed="@(_trainingActivity == ActivityLevel.Moderate)" @onclick="() => _trainingActivity = ActivityLevel.Moderate"><strong>Średnia</strong><span>3–5 regularnych treningów</span></button>
                                    <button type="button" class="@ChoiceClass(_trainingActivity == ActivityLevel.High)" aria-pressed="@(_trainingActivity == ActivityLevel.High)" @onclick="() => _trainingActivity = ActivityLevel.High"><strong>Wysoka</strong><span>5+ ciężkich sesji</span></button>
                                </div>
                                <label class="mobile-number-field training-count-field"><span>Ile treningów planujesz w tygodniu?</span><input type="text" inputmode="numeric" autocomplete="off" @bind="_plannedTrainingsInput" @bind:event="oninput" placeholder="np. 4" /></label>
                            </section>
                            break;
                        case 9:
                            <section class="goal-result">
                                <span class="card-kicker">Twój wynik</span>
                                <p>Cel bazowy obowiązuje w dzień bez treningu. Dodatkowa energia pojawi się dopiero po ukończeniu sesji.</p>
                                <div class="goal-calorie-split">
                                    <div><span>Dzień bez treningu</span><strong>@_targetCalories?.ToString("0") kcal</strong></div>
                                    <div><span>Przykładowy dzień treningowy</span><strong>@TypicalTrainingCalories.ToString("0") kcal</strong><small>około +@TypicalTrainingBonus.ToString("0") kcal za 60 min i 15 serii</small></div>
                                    <div class="goal-date"><span>Szacowana data osiągnięcia celu</span><strong>@EstimatedGoalDate</strong><small>@GoalPaceCopy</small></div>
                                </div>
                                <div class="goal-result-dials">
                                    <label class="goal-result-dial energy">
                                        <span>Kalorie</span>
                                        <input type="number" min="0" step="1" @bind="_targetCalories" aria-label="Kalorie dziennie" />
                                        <small>kcal</small>
                                    </label>
                                    <label class="goal-result-dial protein">
                                        <span>Białko</span>
                                        <input type="number" min="0" step="1" @bind="_proteinG" aria-label="Białko dziennie" />
                                        <small>g</small>
                                    </label>
                                    <label class="goal-result-dial fat">
                                        <span>Tłuszcze</span>
                                        <input type="number" min="0" step="1" @bind="_fatG" aria-label="Tłuszcze dziennie" />
                                        <small>g</small>
                                    </label>
                                    <label class="goal-result-dial carbs">
                                        <span>Węglowodany</span>
                                        <input type="number" min="0" step="1" @bind="_carbsG" aria-label="Węglowodany dziennie" />
                                        <small>g</small>
                                    </label>
                                </div>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="SaveNutritionTarget">Zapisz cel i używaj od dzisiaj</MudButton>
                                <MudButton Variant="Variant.Text" FullWidth="true" OnClick="() => _goalStep = 1">Przelicz od początku</MudButton>
                            </section>
                            break;
                    }

                    @if (_goalStep < 9)
                    {
                        <div class="goal-wizard-actions">
                            @if (_goalStep > 1)
                            {
                                <MudButton Variant="Variant.Outlined" OnClick="PreviousGoalStep">Wstecz</MudButton>
                            }
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NextGoalStep">@(_goalStep == 8 ? "Wylicz zapotrzebowanie" : "Dalej")</MudButton>
                        </div>
                    }
                </MudPaper>
            </MudTabPanel>

            <MudTabPanel Text="Ustawienia">
                <div class="profile-settings-layout">
                    <MudPaper Class="profile-section settings-section" Elevation="0">
                        <div class="profile-section-heading"><span class="card-kicker">Rytm aplikacji</span><h2>Ustawienia</h2><p>Każda grupa otwiera się osobno. Zapisujesz tylko to, co właśnie zmieniasz.</p></div>
                        <nav class="settings-menu" aria-label="Ustawienia aplikacji">
                            <a href="/profile/settings/nutrition"><MudIcon Icon="@Icons.Material.Outlined.Flag" /><span><strong>Cele żywieniowe</strong><small>@(_targetCalories?.ToString("0") ?? "—") kcal · B @_proteinG.ToString("0") g · T @_fatG.ToString("0") g · W @_carbsG.ToString("0") g</small></span><MudIcon Icon="@Icons.Material.Filled.ChevronRight" /></a>
                            <a href="/profile/settings/meals"><MudIcon Icon="@Icons.Material.Outlined.Restaurant" /><span><strong>Posiłki i godziny</strong><small>@_mealSlots.Count aktywnych sekcji</small></span><MudIcon Icon="@Icons.Material.Filled.ChevronRight" /></a>
                            <a href="/profile/settings/reminders"><MudIcon Icon="@Icons.Material.Outlined.Notifications" /><span><strong>Przypomnienia</strong><small>@(_mealRemindersEnabled ? "Włączone" : "Wyłączone")</small></span><MudIcon Icon="@Icons.Material.Filled.ChevronRight" /></a>
                            <a href="/profile/settings/workouts"><MudIcon Icon="@Icons.Material.Outlined.FitnessCenter" /><span><strong>Ustawienia treningów</strong><small>@_defaultSets serie · @_defaultRepetitions powt. · @_defaultRestSeconds s przerwy</small></span><MudIcon Icon="@Icons.Material.Filled.ChevronRight" /></a>
                            <a href="/profile/settings/calendar"><MudIcon Icon="@Icons.Material.Outlined.CalendarMonth" /><span><strong>Kalendarz i tydzień</strong><small>Początek: @WeekDayName(_weekStartsOn)</small></span><MudIcon Icon="@Icons.Material.Filled.ChevronRight" /></a>
                            <a href="/profile/settings/appearance"><MudIcon Icon="@Icons.Material.Outlined.Palette" /><span><strong>Wygląd</strong><small>@ThemeName(_themePreference)</small></span><MudIcon Icon="@Icons.Material.Filled.ChevronRight" /></a>
                        </nav>
                    </MudPaper>

                    <MudPaper Class="profile-section account-section" Elevation="0">
                        <div class="profile-section-heading"><span class="card-kicker">Konto</span><h2>Dostęp i prywatność</h2><p>Zarządzaj sesją i sprawdź, jak FormaAI chroni Twoje dane.</p></div>
                        <nav class="account-menu" aria-label="Dostęp i prywatność">
                            @if (_user!.IsAdmin)
                            {
                                <a href="/admin"><MudIcon Icon="@Icons.Material.Outlined.AdminPanelSettings" /><span><strong>Panel administratora</strong><small>Konfiguracja aplikacji i integracji</small></span><MudIcon Icon="@Icons.Material.Filled.ChevronRight" /></a>
                            }
                            <a href="/privacy"><MudIcon Icon="@Icons.Material.Outlined.Shield" /><span><strong>Prywatność i źródła danych</strong><small>Zasady przetwarzania informacji</small></span><MudIcon Icon="@Icons.Material.Filled.ChevronRight" /></a>
                            <button type="button" @onclick="Logout"><MudIcon Icon="@Icons.Material.Outlined.Logout" /><span><strong>Wyloguj się</strong><small>Zakończ sesję na tym urządzeniu</small></span><MudIcon Icon="@Icons.Material.Filled.ChevronRight" /></button>
                        </nav>
                    </MudPaper>
                </div>

                <section class="danger-zone" aria-labelledby="danger-zone-title">
                    <header class="danger-zone-heading">
                        <MudIcon Icon="@Icons.Material.Outlined.WarningAmber" />
                        <div><span class="card-kicker">Nieodwracalna operacja</span><h2 id="danger-zone-title">Strefa zagrożenia</h2><p>Usunięcie konta kasuje profil, dziennik, plany treningowe i historię progresu.</p></div>
                    </header>
                    <MudExpansionPanels Class="account-delete">
                        <MudExpansionPanel Text="Usuń konto i wszystkie dane">
                            <MudAlert Severity="Severity.Error" Dense="true">Tej operacji nie można cofnąć. Przed usunięciem upewnij się, że nie potrzebujesz zapisanej historii.</MudAlert>
                            <MudTextField @bind-Value="_deletePassword" Label="Hasło" InputType="InputType.Password" />
                            <MudTextField @bind-Value="_deleteConfirmation" Label="Wpisz USUŃ" HelperText="Wielkimi literami, aby potwierdzić świadomą decyzję." />
                            <MudButton Variant="Variant.Filled" Color="Color.Error" FullWidth="true" Disabled="@(_deleteConfirmation != "USUŃ" || string.IsNullOrEmpty(_deletePassword))" OnClick="DeleteAccount" Class="mt-3">Usuń konto na stałe</MudButton>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                </section>
            </MudTabPanel>
        </MudTabs>
    }
</MudContainer>

@code {
    private CurrentUserResponse? _user;
    private UserProfileResponse? _profile;
    private bool _loading = true;
    private DateTime? _birthDate;
    private BiologicalSex? _sex;
    private ActivityLevel? _workActivity;
    private ActivityLevel? _trainingActivity;
    private BodyGoal? _goal;
    private decimal? _heightCm;
    private decimal? _currentWeightKg;
    private decimal? _startingWeightKg;
    private decimal? _targetWeightKg;
    private decimal _weeklyWeightChangeKg = 0.5m;
    private int? _plannedTrainings;
    private string _heightInput = string.Empty;
    private string _currentWeightInput = string.Empty;
    private string _targetWeightInput = string.Empty;
    private string _plannedTrainingsInput = string.Empty;
    private int _toleranceKcal = 100;
    private string _timeZoneId = "Europe/Warsaw";
    private List<string> _mealSlots = [];
    private IReadOnlyList<MealScheduleEntry> _mealSchedule = [];
    private int _defaultRestSeconds = 90;
    private int _defaultRepetitions = 10;
    private int _defaultSets = 3;
    private DayOfWeek _weekStartsOn = DayOfWeek.Monday;
    private string _themePreference = "system";
    private bool _mealRemindersEnabled;
    private int _mealReminderMinutesBefore;
    private decimal? _targetCalories;
    private decimal _proteinG;
    private decimal _fatG;
    private decimal _carbsG;
    private string _deletePassword = string.Empty;
    private string _deleteConfirmation = string.Empty;
    private int _goalStep = 1;
    private char Initial => char.ToUpperInvariant(_profile!.Email[0]);
    private string GoalName => _goal switch { BodyGoal.Reduction => "Redukcja", BodyGoal.Maintenance => "Utrzymanie", BodyGoal.MuscleGain => "Budowanie masy", _ => "Cel nieustawiony" };
    private decimal GoalProgress => _goalStep / 9m * 100m;
    private decimal TypicalTrainingBonus => _trainingActivity switch
    {
        ActivityLevel.Light => 270,
        ActivityLevel.Moderate => 360,
        ActivityLevel.High => 450,
        _ => 210
    };
    private decimal TypicalTrainingCalories => (_targetCalories ?? 0) + TypicalTrainingBonus;
    private string TargetWeightHint => _goal == BodyGoal.Maintenance
        ? "Przy utrzymaniu możesz podać obecną masę."
        : "Podaj wagę, do której chcesz dojść.";
    private string EstimatedGoalDate
    {
        get
        {
            if (_goal == BodyGoal.Maintenance) return "Cel ciągły";
            if (_currentWeightKg is null || _targetWeightKg is null || _weeklyWeightChangeKg <= 0) return "—";
            var weeks = Math.Abs(_targetWeightKg.Value - _currentWeightKg.Value) / _weeklyWeightChangeKg;
            return DateTime.Today.AddDays((double)Math.Ceiling(weeks * 7m)).ToString("d MMMM yyyy", new System.Globalization.CultureInfo("pl-PL"));
        }
    }
    private string GoalPaceCopy => _goal == BodyGoal.Maintenance ? "Bilans bez planowanej zmiany masy" : $"przy tempie około {_weeklyWeightChangeKg:0.##} kg tygodniowo";
    private string WeightDifference
    {
        get
        {
            var difference = _targetWeightKg!.Value - _currentWeightKg!.Value;
            if (Math.Abs(difference) < .05m) return "Chcesz utrzymać obecną masę.";
            return difference < 0
                ? $"Chcesz zredukować {Math.Abs(difference):0.#} kg."
                : $"Chcesz zwiększyć masę o {difference:0.#} kg.";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _user = await Account.GetCurrentUser();
        if (_user is null) { Navigation.NavigateTo("/"); return; }
        _profile = await Account.GetProfile();
        var target = await Nutrition.GetCurrentTarget();
        var weight = await ProgressApi.GetWeight(DateOnly.FromDateTime(DateTime.Today.AddDays(-90)), DateOnly.FromDateTime(DateTime.Today));

        _birthDate = _profile.BirthDate?.ToDateTime(TimeOnly.MinValue);
        _sex = _profile.Sex;
        _workActivity = _profile.WorkActivityLevel ?? _profile.ActivityLevel;
        _trainingActivity = _profile.TrainingActivityLevel ?? ActivityLevel.Low;
        _goal = _profile.Goal;
        _heightCm = _profile.HeightCm;
        _startingWeightKg = _profile.StartingWeightKg;
        _targetWeightKg = _profile.TargetWeightKg;
        _weeklyWeightChangeKg = _profile.WeeklyWeightChangeKg > 0 ? _profile.WeeklyWeightChangeKg : 0.5m;
        _currentWeightKg = weight?.CurrentAverageKg ?? _profile.StartingWeightKg;
        _plannedTrainings = _profile.PlannedTrainingsPerWeek;
        _heightInput = NumberText(_heightCm);
        _currentWeightInput = NumberText(_currentWeightKg);
        _targetWeightInput = NumberText(_targetWeightKg);
        _plannedTrainingsInput = (_plannedTrainings ?? 0).ToString();
        _toleranceKcal = _profile.CalorieToleranceKcal;
        _timeZoneId = _profile.TimeZoneId;
        _mealSlots = _profile.MealSlots?.ToList() ?? ["Śniadanie", "Lunch", "Obiad", "Przekąska", "Kolacja"];
        _mealSchedule = _profile.MealSchedule ?? [];
        _defaultRestSeconds = _profile.DefaultRestSeconds;
        _defaultRepetitions = _profile.DefaultRepetitions;
        _defaultSets = _profile.DefaultSets;
        _weekStartsOn = _profile.WeekStartsOn;
        _themePreference = _profile.ThemePreference;
        _mealRemindersEnabled = _profile.MealRemindersEnabled;
        _mealReminderMinutesBefore = _profile.MealReminderMinutesBefore;
        if (target is not null)
        {
            _targetCalories = target.CaloriesKcal;
            _proteinG = target.ProteinG;
            _fatG = target.FatG;
            _carbsG = target.CarbohydratesG;
            _goalStep = 9;
        }
        _loading = false;
    }

    private void PreviousGoalStep() => _goalStep = Math.Max(1, _goalStep - 1);

    private void NextGoalStep()
    {
        var numberError = ParseCurrentStep();
        if (numberError is not null)
        {
            Snackbar.Add(numberError, Severity.Info);
            return;
        }

        var error = _goalStep switch
        {
            1 when _goal is null => "Wybierz cel.",
            2 when _sex is null => "Wybierz płeć.",
            3 when _birthDate is null => "Podaj datę urodzenia.",
            4 when _heightCm is null => "Podaj wzrost.",
            5 when _currentWeightKg is null => "Podaj obecną masę.",
            6 when _targetWeightKg is null => "Podaj docelową masę.",
            6 when _goal == BodyGoal.Reduction && _targetWeightKg >= _currentWeightKg => "Przy redukcji masa docelowa powinna być niższa od obecnej.",
            6 when _goal == BodyGoal.MuscleGain && _targetWeightKg <= _currentWeightKg => "Przy budowaniu masy cel powinien być wyższy od obecnej masy.",
            6 when _goal != BodyGoal.Maintenance && _weeklyWeightChangeKg is < 0.05m or > 1.5m => "Wybierz tempo od 0,05 do 1,5 kg tygodniowo.",
            7 when _workActivity is null => "Wybierz aktywność w pracy.",
            8 when _trainingActivity is null => "Wybierz aktywność treningową.",
            _ => null
        };

        if (error is not null)
        {
            Snackbar.Add(error, Severity.Info);
            return;
        }

        if (_goalStep == 5)
        {
            _startingWeightKg ??= _currentWeightKg;
            _targetWeightKg ??= _currentWeightKg;
        }

        if (_goalStep == 8)
        {
            CalculateTarget();
            _goalStep = 9;
            return;
        }

        _goalStep++;
    }

    private string? ParseCurrentStep()
    {
        if (_goalStep == 4 && !TryDecimal(_heightInput, 50, 280, out _heightCm)) return "Podaj wzrost od 50 do 280 cm.";
        if (_goalStep == 5 && !TryDecimal(_currentWeightInput, 20, 500, out _currentWeightKg)) return "Podaj masę od 20 do 500 kg.";
        if (_goalStep == 6 && !TryDecimal(_targetWeightInput, 20, 500, out _targetWeightKg)) return "Podaj masę docelową od 20 do 500 kg.";
        if (_goalStep == 8)
        {
            if (!int.TryParse(_plannedTrainingsInput, out var count) || count is < 0 or > 14) return "Podaj liczbę treningów od 0 do 14.";
            _plannedTrainings = count;
        }
        return null;
    }

    private static bool TryDecimal(string text, decimal min, decimal max, out decimal? value)
    {
        value = null;
        var normalized = text.Trim().Replace(',', '.');
        if (!decimal.TryParse(normalized, System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out var parsed) || parsed < min || parsed > max) return false;
        value = parsed;
        return true;
    }

    private static string NumberText(decimal? value) => value?.ToString("0.#", System.Globalization.CultureInfo.GetCultureInfo("pl-PL")) ?? string.Empty;

    private void CalculateTarget()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var birth = DateOnly.FromDateTime(_birthDate!.Value);
        var age = today.Year - birth.Year - (today < birth.AddYears(today.Year - birth.Year) ? 1 : 0);
        var bmr = 10m * _currentWeightKg!.Value + 6.25m * _heightCm!.Value - 5m * age + (_sex == BiologicalSex.Male ? 5m : -161m);
        var factor = _workActivity switch { ActivityLevel.Low => 1.2m, ActivityLevel.Light => 1.32m, ActivityLevel.Moderate => 1.45m, _ => 1.6m };
        var weeklyEnergy = _weeklyWeightChangeKg * 7700m;
        var adjustment = _goal switch { BodyGoal.Reduction => -weeklyEnergy / 7m, BodyGoal.MuscleGain => weeklyEnergy / 7m, _ => 0m };
        _targetCalories = Math.Round(Math.Max(1200m, bmr * factor + adjustment));
        _proteinG = Math.Round(_currentWeightKg.Value * 2m);
        _fatG = Math.Round(_currentWeightKg.Value * .9m);
        _carbsG = Math.Round(Math.Max(0m, (_targetCalories.Value - _proteinG * 4m - _fatG * 9m) / 4m));
    }

    private async Task SaveProfile() => await Run(async () =>
    {
        await SaveProfileData();
        Snackbar.Add("Profil zapisany.", Severity.Success);
    }, "Nie udało się zapisać profilu.");

    private async Task SaveNutritionTarget() => await Run(async () =>
    {
        _startingWeightKg ??= _currentWeightKg;
        await SaveProfileData();
        await Nutrition.SaveTarget(new SaveNutritionTargetRequest(DateOnly.FromDateTime(DateTime.Today), _targetCalories!.Value, _proteinG, _fatG, _carbsG));
        Snackbar.Add("Cel zapisany. Od dziś jest podstawą bilansu kalorii.", Severity.Success);
    }, "Nie udało się zapisać celu żywieniowego.");

    private async Task SaveProfileData()
    {
        _profile = await Account.UpdateProfile(new UpdateUserProfileRequest(
            _timeZoneId, _heightCm, _startingWeightKg, _goal, _plannedTrainings,
            _birthDate is null ? null : DateOnly.FromDateTime(_birthDate.Value), _sex, _workActivity, _targetWeightKg, _toleranceKcal,
            _mealSlots.Where(x => !string.IsNullOrWhiteSpace(x)).Select(x => x.Trim()).ToList(),
            _workActivity, _trainingActivity, _mealSchedule, _defaultRestSeconds, _defaultRepetitions, _defaultSets,
            _weekStartsOn, _themePreference, _mealRemindersEnabled, _mealReminderMinutesBefore,
            WeeklyWeightChangeKg: _weeklyWeightChangeKg));
    }

    private static string WeekDayName(DayOfWeek day) => day switch { DayOfWeek.Sunday => "niedziela", DayOfWeek.Saturday => "sobota", _ => "poniedziałek" };
    private static string ThemeName(string theme) => theme switch { "dark" => "Ciemny", "light" => "Jasny", _ => "Zgodny z telefonem" };

    private static string ChoiceClass(bool selected) => selected ? "goal-choice selected" : "goal-choice";

    private async Task Logout()
    {
        await Account.Logout();
        Navigation.NavigateTo("/", forceLoad: true);
    }

    private async Task DeleteAccount() => await Run(async () =>
    {
        await Account.DeleteAccount(new DeleteAccountRequest(_deletePassword, _deleteConfirmation));
        Navigation.NavigateTo("/", forceLoad: true);
    }, "Nie udało się usunąć konta. Sprawdź hasło i potwierdzenie.");

    private async Task Run(Func<Task> action, string error)
    {
        try { await action(); }
        catch (HttpRequestException) { Snackbar.Add(error, Severity.Error); }
    }
}
