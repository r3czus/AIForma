@page "/progress"
@inject AccountClient Account
@inject ProgressClient ProgressApi
@inject TrainingClient TrainingApi
@inject NavigationManager Navigation

<PageTitle>Progres · FormaAI</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="content-wrap module-page progress-page progress-v3">
    <header class="module-heading progress-heading">
        <div>
            <span class="page-kicker">Twój kierunek</span>
            <MudText Typo="Typo.h4">Progres</MudText>
            <p>Dieta, trening i zmiany sylwetki w jednym rytmie.</p>
        </div>
    </header>

    @if (_loading)
    {
        <div class="page-loader compact"><MudProgressCircular Indeterminate="true" Color="Color.Primary" /><span>Liczymy trend</span></div>
    }
    else
    {
        <nav class="progress-tabs" aria-label="Widoki progresu">
            <button class="@TabClass(0)" @onclick="() => _tab = 0"><i class="overview"></i>Na dziś</button>
            <button class="@TabClass(1)" @onclick="() => _tab = 1"><i class="diet"></i>Dieta</button>
            <button class="@TabClass(2)" @onclick="() => _tab = 2"><i class="training"></i>Trening</button>
        </nav>

        <section class="progress-timebar" aria-label="Zakres i okres danych">
            <div class="progress-ranges" role="group" aria-label="Zakres danych">
                @foreach (var days in Ranges)
                {
                    <button class="@(days == _rangeDays ? "active" : null)" @onclick="() => ChangeRange(days)">@(days == 365 ? "Rok" : $"{days} dni")</button>
                }
            </div>
            <div class="progress-period-nav">
                <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" OnClick="() => MovePeriod(-1)" aria-label="Poprzedni okres" />
                <span>@PeriodLabel</span>
                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Disabled="@IsCurrentPeriod" OnClick="() => MovePeriod(1)" aria-label="Następny okres" />
            </div>
        </section>

        @if (_tab == 0)
        {
            <section class="progress-direction progress-overview-hero">
                <div><span class="card-kicker">@RangeKicker</span><h2>@DirectionTitle</h2><p>@DirectionNote</p></div>
                <div class="direction-score"><strong>@DirectionScore%</strong><span>rytm okresu</span></div>
            </section>

            @if (_summary is not null)
            {
                <div class="week-summary-grid progress-overview-stats">
                    <MudPaper Class="week-summary-card nutrition-summary" Elevation="0">
                        <div class="summary-card-top"><MudIcon Icon="@Icons.Material.Outlined.Restaurant" /><div><span>Dieta</span><strong>@_summary.Nutrition.DaysOnCalories / @_summary.Nutrition.LoggedDays dni w celu</strong></div></div>
                        <div class="summary-progress"><i style="width: @PercentWidth(_summary.Nutrition.CalorieAdherencePercent)"></i></div>
                        <p>@NutritionNote</p>
                    </MudPaper>
                    <MudPaper Class="week-summary-card training-summary" Elevation="0">
                        <div class="summary-card-top"><MudIcon Icon="@Icons.Material.Outlined.FitnessCenter" /><div><span>Trening</span><strong>@_summary.Training.CompletedWorkouts / @_summary.Training.PlannedWorkouts sesji</strong></div></div>
                        <div class="summary-progress"><i style="width: @PercentWidth(TrainingPlanPercent)"></i></div>
                        <p>@TrainingNote</p>
                    </MudPaper>
                </div>
            }

            @CalendarBlock()

            <section class="progress-trends" aria-label="Najważniejsze trendy">
                <div><span>Trend masy</span><strong>@Signed(_weight?.ChangeKg) kg</strong><small>@(_weight?.CurrentAverageKg?.ToString("0.0") ?? "—") kg średnio</small></div>
                <div><span>Objętość treningowa</span><strong>@Signed(_summary?.Training.VolumeChangePercent)%</strong><small>względem poprzedniego okresu</small></div>
            </section>

            <section class="progress-tools" aria-label="Narzędzia progresu">
                @ToolLink("/progress/weekly", Icons.Material.Outlined.FactCheck, "Podsumowanie tygodnia", "Regeneracja i następny krok")
                @ToolLink("/progress/measurements", Icons.Material.Outlined.MonitorWeight, "Pomiary", "Masa i obwody")
                @ToolLink("/progress/photos", Icons.Material.Outlined.PhotoCamera, "Zdjęcia progresu", "Prywatne porównania")
                @ToolLink("/progress/achievements", Icons.Material.Outlined.EmojiEvents, "Osiągnięcia", "Wszystkie kamienie milowe")
            </section>
        }
        else if (_tab == 1)
        {
            @if (_summary is not null)
            {
                <section class="progress-section-hero diet-section-hero" aria-label="Podsumowanie diety">
                    <div class="progress-section-copy"><span class="card-kicker">@RangeKicker</span><h2>@DietTitle</h2><p>@NutritionNote</p></div>
                    <div class="progress-section-metrics">
                        @Metric("W celu", $"{_summary.Nutrition.DaysOnCalories} / {_summary.Nutrition.LoggedDays} dni", "kalorie")
                        @Metric("Średnio", $"{_summary.Nutrition.AverageCalories:0} kcal", $"cel {_summary.Nutrition.AverageTargetCalories:0}")
                        @Metric("Białko", $"{_summary.Nutrition.DaysOnProtein} / {_summary.Nutrition.LoggedDays} dni", $"średnio {_summary.Nutrition.AverageProteinG:0} g")
                        @Metric("Bilans", $"{Signed(_summary.Nutrition.AverageCalorieDifference)} kcal", "dziennie")
                    </div>
                </section>
            }

            @if (_nutrition?.Days.Any(x => x.HasMeals) == true)
            {
                <MudPaper Class="progress-card" Elevation="0">
                    <div class="progress-card-heading"><span class="card-kicker">Energia w czasie</span><MudText Typo="Typo.h6">Kalorie a cel</MudText><p>@PeriodLabel</p></div>
                    <MudChart ChartType="ChartType.Line" ChartSeries="@NutritionSeries" XAxisLabels="@NutritionLabels" Width="100%" Height="230px" />
                    <div class="chart-label">Makroskładniki w zapisanych dniach</div>
                    <MudChart ChartType="ChartType.Line" ChartSeries="@MacroTrendSeries" XAxisLabels="@NutritionLabels" Width="100%" Height="230px" />
                </MudPaper>
            }

            <MudPaper Class="progress-card" Elevation="0">
                <div class="progress-card-heading measurement-heading"><div><span class="card-kicker">Pomiar ciała</span><MudText Typo="Typo.h6">Masa i obwód</MudText><p>Wykresy obejmują @PeriodLabel.ToLowerInvariant().</p></div><MudButton Href="/progress/measurements" Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Outlined.Add">Dodaj pomiary</MudButton></div>
                @if (_weight?.Points.Count > 0)
                {
                    <div class="chart-label">Trend masy · średnia 7 dni</div>
                    <div class="weight-trend-chart">
                        <span class="chart-max">@WeightChartMax.ToString("0.0") kg</span>
                        <svg viewBox="0 0 100 46" preserveAspectRatio="none" role="img" aria-label="Trend masy ciała"><line x1="4" y1="4" x2="96" y2="4" /><line x1="4" y1="42" x2="96" y2="42" /><polyline points="@WeightChartPolyline" /></svg>
                        <span class="chart-min">@WeightChartMin.ToString("0.0") kg</span>
                        <div><span>@_weight.Points.First().Date.ToString("dd.MM")</span><span>@_weight.Points.Last().Date.ToString("dd.MM")</span></div>
                    </div>
                    <div class="metric-row"><div><span>Średnia 7 dni</span><strong>@_weight.CurrentAverageKg?.ToString("0.00") kg</strong></div><div><span>Zmiana trendu</span><strong>@Signed(_weight.ChangeKg) kg</strong></div></div>
                }
                else
                {
                    <div class="module-empty"><MudIcon Icon="@Icons.Material.Outlined.MonitorWeight" /><div><strong>Brakuje pomiarów w tym okresie</strong><span>Dodaj pomiar, aby rozpocząć linię trendu.</span></div></div>
                }
            </MudPaper>

            @if (_measurements.Count > 0)
            {
                <MudPaper Class="progress-card" Elevation="0">
                    <div class="progress-card-heading"><span class="card-kicker">Obwody ciała</span><MudText Typo="Typo.h6">Zmiana wymiarów</MudText></div>
                    <div class="body-metric-filters">@foreach (var metric in BodyMetrics) { <button class="@(_visibleBodyMetrics.Contains(metric.Key) ? "selected" : null)" @onclick="() => ToggleBodyMetric(metric.Key)">@metric.Label</button> }</div>
                    <MudChart ChartType="ChartType.Line" ChartSeries="@BodySeries" XAxisLabels="@BodyLabels" Width="100%" Height="260px" />
                </MudPaper>
            }
        }
        else
        {
            @if (_summary is not null)
            {
                <section class="progress-section-hero training-section-hero" aria-label="Wyniki treningów">
                    <div class="progress-section-copy"><span class="card-kicker">@RangeKicker</span><h2>@TrainingTitle</h2><p>@TrainingNote</p></div>
                    <div class="progress-section-metrics">
                        @Metric("Sesje", $"{_summary.Training.CompletedWorkouts} / {_summary.Training.PlannedWorkouts}", "wykonane")
                        @Metric("Objętość", $"{_summary.Training.TotalVolumeKg:0} kg", $"{Signed(_summary.Training.VolumeChangePercent)}% do poprzedniego okresu")
                        @Metric("Serie", _summary.Training.WorkingSets.ToString(), $"{_summary.Training.SetCompletionPercent:0.#}% wykonanych")
                        @Metric("Czas", Duration(_summary.Training.TotalMinutes), "łącznie")
                    </div>
                </section>
            }

            <MudPaper Class="progress-card" Elevation="0">
                <div class="progress-card-heading"><span class="card-kicker">Regularność</span><MudText Typo="Typo.h6">Ukończone treningi</MudText><p>@PeriodLabel</p></div>
                @if (_consistency?.Weeks.Count > 0) { <MudChart ChartType="ChartType.Bar" ChartSeries="@ConsistencySeries" XAxisLabels="@ConsistencyLabels" Width="100%" Height="220px" /> }
                else { <div class="module-empty"><MudIcon Icon="@Icons.Material.Outlined.EventBusy" /><div><strong>Brak ukończonych sesji</strong><span>W tym okresie nie ma jeszcze treningów.</span></div></div> }
            </MudPaper>

            <MudPaper Class="progress-card" Elevation="0">
                <div class="progress-card-heading"><span class="card-kicker">Dziennik siły</span><MudText Typo="Typo.h6">Progres ćwiczenia</MudText><p>Objętość i szacowany e1RM są pokazane osobno.</p></div>
                <MudSelect T="Guid?" Value="_selectedExercise" ValueChanged="LoadExercise" Label="Wybierz ćwiczenie">
                    @foreach (var exercise in _exercises) { <MudSelectItem T="Guid?" Value="@((Guid?)exercise.Id)">@exercise.Name</MudSelectItem> }
                </MudSelect>
                @if (_exerciseProgress?.Points.Count > 0)
                {
                    <div class="progress-chart-stack"><div><span class="chart-label">Objętość ćwiczenia</span><MudChart ChartType="ChartType.Line" ChartSeries="@ExerciseVolumeSeries" XAxisLabels="@ExerciseLabels" Width="100%" Height="190px" /></div><div><span class="chart-label">Szacowany e1RM</span><MudChart ChartType="ChartType.Line" ChartSeries="@ExerciseStrengthSeries" XAxisLabels="@ExerciseLabels" Width="100%" Height="190px" /></div></div>
                    <div class="metric-row"><div><span>Zmiana objętości</span><strong>@Signed(_exerciseProgress.VolumeChangePercent)%</strong></div><div><span>Zmiana e1RM</span><strong>@Signed(_exerciseProgress.EstimatedOneRepMaxChangeKg) kg</strong></div></div>
                }
            </MudPaper>

            @if (_muscleVolume.Count > 0)
            {
                <MudPaper Class="progress-card" Elevation="0">
                    <div class="progress-card-heading"><span class="card-kicker">Rozkład pracy</span><MudText Typo="Typo.h6">Zaangażowanie partii</MudText><p>@PeriodLabel</p></div>
                    <div class="muscle-work-layout"><MudChart ChartType="ChartType.Donut" InputData="@MuscleWorkData" InputLabels="@MuscleWorkLabels" Width="100%" Height="240px" /><div class="muscle-volume-list">@foreach (var group in _muscleVolume) { <div><span>@MuscleName(group.MuscleGroup)</span><i><b style="@($"width:{group.WorkPercent:0.#}%")"></b></i><strong>@group.WorkPercent.ToString("0.#")% · @group.WorkingSets.ToString("0.#") ważonych serii</strong></div> }</div></div>
                </MudPaper>
            }
        }
    }
</MudContainer>

@code {
    private static readonly int[] Ranges = [7, 30, 90, 180, 365];
    private static readonly System.Globalization.CultureInfo Pl = new("pl-PL");
    private int _tab;
    private int _rangeDays = 7;
    private DateOnly _periodStart;
    private DayOfWeek _weekStartsOn = DayOfWeek.Monday;
    private bool _loading = true;
    private WeightProgressResponse? _weight;
    private ConsistencyResponse? _consistency;
    private NutritionAdherenceResponse? _nutrition;
    private ProgressWeekSummaryResponse? _summary;
    private ExerciseProgressResponse? _exerciseProgress;
    private IReadOnlyList<ExerciseResponse> _exercises = [];
    private IReadOnlyList<BodyMeasurementResponse> _measurements = [];
    private IReadOnlyList<MuscleVolumePoint> _muscleVolume = [];
    private NutritionAdherencePoint? _selectedDay;
    private Guid? _selectedExercise;
    private static readonly (string Key, string Label)[] BodyMetrics = [("waist", "Brzuch / talia"), ("chest", "Klatka"), ("hips", "Biodra"), ("arm", "Ramię"), ("thigh", "Udo")];
    private readonly HashSet<string> _visibleBodyMetrics = ["waist", "hips"];

    private DateOnly PeriodEnd => _rangeDays switch { 7 => _periodStart.AddDays(6), 30 => _periodStart.AddMonths(1).AddDays(-1), _ => _periodStart.AddDays(_rangeDays - 1) };
    private bool IsCurrentPeriod => _periodStart >= CurrentPeriodStart();
    private string PeriodLabel => DateLabel(_periodStart, PeriodEnd);
    private decimal TrainingPlanPercent => _summary?.Training.PlannedWorkouts > 0 ? Math.Min(100, _summary.Training.CompletedWorkouts * 100m / _summary.Training.PlannedWorkouts) : 0;
    private int DirectionScore => (int)Math.Round(((_summary?.Nutrition.CalorieAdherencePercent ?? 0) + TrainingPlanPercent) / 2);
    private string DirectionTitle => DirectionScore >= 75 ? "Dobry rytm" : DirectionScore >= 45 ? "Kierunek jest, rytm do poprawy" : "Wróć do podstaw";
    private string DirectionNote => DirectionScore >= 75 ? "Plan jest realizowany regularnie. Patrz na trend i trzymaj tempo." : "Najwięcej zmieni jeden powtarzalny dzień jedzenia i jedna ukończona sesja.";
    private string RangeKicker => _rangeDays == 365 ? "Ostatni rok" : $"Ostatnie {_rangeDays} dni";
    private string DietTitle => (_summary?.Nutrition.CalorieAdherencePercent ?? 0) >= 70 ? "Dobry rytm. Utrzymaj kierunek." : "Regularność wygrywa z perfekcją.";
    private string TrainingTitle => TrainingPlanPercent >= 80 ? "Plan trzyma tempo." : "Każda ukończona sesja się liczy.";
    private string NutritionNote => _summary?.Nutrition.LoggedDays == 0 ? "Zapisz posiłki, aby policzyć realizację." : $"Średnio {Signed(_summary?.Nutrition.AverageCalorieDifference)} kcal względem celu.";
    private string TrainingNote => _summary?.Training.CompletedWorkouts == 0 ? "Ukończ pierwszą sesję w tym okresie." : $"{_summary?.Training.WorkingSets} serii roboczych · {Duration(_summary?.Training.TotalMinutes ?? 0)}.";
    private decimal WeightChartMax => _weight?.Points.Max(x => x.SevenDayAverageKg) ?? 0;
    private decimal WeightChartMin => _weight?.Points.Count > 0 ? Math.Min(_weight.Points.Min(x => x.SevenDayAverageKg), WeightChartMax - 1) : 0;
    private string WeightChartPolyline => _weight?.Points.Count > 0 ? string.Join(' ', _weight.Points.Select((p, i) => $"{Invariant(_weight.Points.Count == 1 ? 50 : 4 + i * 92m / (_weight.Points.Count - 1))},{Invariant(4 + (WeightChartMax - p.SevenDayAverageKg) * 38m / Math.Max(1, WeightChartMax - WeightChartMin))}")) : string.Empty;
    private List<ChartSeries> NutritionSeries => [new() { Name = "Spożyte", Data = LoggedDays.Select(x => (double)x.ConsumedKcal).ToArray() }, new() { Name = "Cel", Data = LoggedDays.Select(x => (double)(x.TargetKcal ?? 0)).ToArray() }];
    private List<ChartSeries> MacroTrendSeries => [new() { Name = "Białko", Data = LoggedDays.Select(x => (double)x.ProteinG).ToArray() }, new() { Name = "Tłuszcze", Data = LoggedDays.Select(x => (double)x.FatG).ToArray() }, new() { Name = "Węglowodany", Data = LoggedDays.Select(x => (double)x.CarbohydratesG).ToArray() }];
    private IEnumerable<NutritionAdherencePoint> LoggedDays => _nutrition!.Days.Where(x => x.HasMeals);
    private string[] NutritionLabels => LoggedDays.Select(x => x.Date.ToString("dd.MM")).ToArray();
    private List<ChartSeries> ConsistencySeries => [new() { Name = "Treningi", Data = _consistency!.Weeks.Select(x => (double)x.CompletedWorkouts).ToArray() }];
    private string[] ConsistencyLabels => _consistency!.Weeks.Select(x => x.WeekStarting.ToString("dd.MM")).ToArray();
    private List<ChartSeries> ExerciseVolumeSeries => [new() { Name = "Objętość", Data = _exerciseProgress!.Points.Select(x => (double)x.VolumeKg).ToArray() }];
    private List<ChartSeries> ExerciseStrengthSeries => [new() { Name = "e1RM", Data = _exerciseProgress!.Points.Select(x => (double)(x.EstimatedOneRepMaxKg ?? 0)).ToArray() }];
    private string[] ExerciseLabels => _exerciseProgress!.Points.Select(x => x.Date.ToString("dd.MM")).ToArray();
    private List<ChartSeries> BodySeries => BodyMetrics.Where(x => _visibleBodyMetrics.Contains(x.Key)).Select(x => new ChartSeries { Name = x.Label, Data = BodyMetricData(x.Key) }).ToList();
    private string[] BodyLabels => _measurements.Select(x => x.LocalDate.ToString("dd.MM")).ToArray();
    private double[] MuscleWorkData => _muscleVolume.Select(x => (double)x.WorkPercent).ToArray();
    private string[] MuscleWorkLabels => _muscleVolume.Select(x => MuscleName(x.MuscleGroup)).ToArray();

    protected override async Task OnInitializedAsync()
    {
        if (await Account.GetCurrentUser() is null) { Navigation.NavigateTo("/"); return; }
        var profile = await Account.GetProfile();
        _weekStartsOn = profile.WeekStartsOn;
        _periodStart = CurrentPeriodStart();
        _exercises = await TrainingApi.GetExercises();
        await Reload();
        _loading = false;
    }

    private async Task Reload()
    {
        var to = PeriodEnd;
        var tasks = new Task[]
        {
            LoadWeight(), LoadConsistency(), LoadNutrition(), LoadSummary(), LoadMeasurements(), LoadMuscles()
        };
        await Task.WhenAll(tasks);
        if (_selectedExercise is not null) await LoadExercise(_selectedExercise);
        _selectedDay = _nutrition?.Days.FirstOrDefault(x => x.Date == _selectedDay?.Date);
        async Task LoadWeight() => _weight = await ProgressApi.GetWeight(_periodStart, to);
        async Task LoadConsistency() => _consistency = await ProgressApi.GetConsistency(_periodStart, to);
        async Task LoadNutrition() => _nutrition = await ProgressApi.GetNutritionAdherence(_periodStart, to);
        async Task LoadSummary() => _summary = await ProgressApi.GetWeekSummary(_periodStart, to);
        async Task LoadMeasurements() => _measurements = await ProgressApi.GetBodyMeasurements(_periodStart, to);
        async Task LoadMuscles() => _muscleVolume = await ProgressApi.GetMuscleVolume(_periodStart, to);
    }

    private async Task ChangeRange(int days) { _rangeDays = days; _periodStart = CurrentPeriodStart(); _selectedDay = null; await Reload(); }
    private async Task MovePeriod(int direction) { _periodStart = _rangeDays switch { 7 => _periodStart.AddDays(7 * direction), 30 => _periodStart.AddMonths(direction), _ => _periodStart.AddDays(_rangeDays * direction) }; await Reload(); }
    private async Task LoadExercise(Guid? id) { _selectedExercise = id; _exerciseProgress = id is null ? null : await ProgressApi.GetExercise(id.Value, _periodStart, PeriodEnd); }
    private DateOnly CurrentPeriodStart()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        if (_rangeDays == 30) return new DateOnly(today.Year, today.Month, 1);
        if (_rangeDays == 7) return today.AddDays(-((7 + (int)today.DayOfWeek - (int)_weekStartsOn) % 7));
        return today.AddDays(-(_rangeDays - 1));
    }

    private RenderFragment CalendarBlock() => __builder =>
    {
        <MudPaper Class="progress-card progress-rhythm" Elevation="0">
            <div class="progress-card-heading"><span class="card-kicker">@(_rangeDays <= 30 ? "Rytm okresu" : "Regularność miesiąc po miesiącu")</span><MudText Typo="Typo.h6">Dieta i trening</MudText><p>@PeriodLabel</p></div>
            @if (_rangeDays <= 30)
            {
                <div class="nutrition-calendar @(_rangeDays == 7 ? "week-calendar" : null)">
                    @foreach (var label in CalendarLabels) { <span class="weekday">@label</span> }
                    @for (var i = 0; i < CalendarOffset; i++) { <span></span> }
                    @foreach (var day in _nutrition?.Days ?? []) { <button class="nutrition-day @DayClass(day)" title="@DayStatus(day)" @onclick="() => _selectedDay = day"><b>@day.Date.Day</b></button> }
                </div>
            }
            else
            {
                <div class="period-heatmaps">
                    @foreach (var month in (_nutrition?.Days ?? []).GroupBy(x => new { x.Date.Year, x.Date.Month }))
                    {
                        var firstDay = new DateOnly(month.Key.Year, month.Key.Month, 1);
                        <section>
                            <strong>@firstDay.ToString("MMMM yyyy", Pl)</strong>
                            <div class="period-calendar">
                                @for (var i = 0; i < MonthOffset(firstDay); i++) { <span></span> }
                                @foreach (var day in month) { <button class="nutrition-day @DayClass(day)" title="@($"{day.Date:dd.MM} · {DayStatus(day)}")" @onclick="() => _selectedDay = day"><b>@day.Date.Day</b></button> }
                            </div>
                        </section>
                    }
                </div>
            }
            @if (_selectedDay is not null) { @DayDetail(_selectedDay) }
            <div class="calendar-legend"><span><i class="workout"></i>Trening</span><span><i class="diet-on"></i>W zakresie</span><span><i class="diet-under"></i>Poniżej</span><span><i class="diet-over"></i>Powyżej</span><span><i class="empty"></i>Brak danych</span></div>
        </MudPaper>
    };

    private RenderFragment DayDetail(NutritionAdherencePoint day) => __builder =>
    {
        <div class="calendar-day-detail">
            <header><strong>@day.Date.ToString("dddd, d MMMM", Pl)</strong><span>Podsumowanie dnia</span></header>
            <section><div><MudIcon Icon="@Icons.Material.Outlined.Restaurant" /><span>Dieta · @DayStatus(day)</span></div>@if (day.HasMeals) { <strong>@day.ConsumedKcal.ToString("0") <small>/ @day.TargetKcal?.ToString("0") kcal</small></strong><p>B @day.ProteinG.ToString("0") g · W @day.CarbohydratesG.ToString("0") g · T @day.FatG.ToString("0") g</p> } else { <p>Brak zapisanych posiłków</p> }<MudButton Href="@($"/food?date={day.Date:yyyy-MM-dd}")" Variant="Variant.Text" Size="Size.Small">Otwórz dziennik</MudButton></section>
            <section><div><MudIcon Icon="@Icons.Material.Outlined.FitnessCenter" /><span>Trening</span></div>@if (day.HasCompletedWorkout) { <strong>@day.WorkoutName</strong><p>@Duration(day.WorkoutMinutes) · @day.WorkoutExercises ćwiczeń · @day.WorkoutSets serii</p><small>Objętość @day.WorkoutVolumeKg.ToString("0") kg</small>@if (day.WorkoutDetails?.Count > 0) { <div class="calendar-workout-exercises">@foreach (var item in day.WorkoutDetails) { <div><strong>@item.Name</strong><span>@item.WorkingSets serii · @item.VolumeKg.ToString("0") kg</span></div> }</div> } @if (day.WorkoutSessionId is Guid id) { <MudButton Href="@($"/workout/{id}")" Variant="Variant.Text" Size="Size.Small">Szczegóły treningu</MudButton> } } else { <p>Bez ukończonego treningu</p> }</section>
            @if (day.Achievements?.Count > 0) { <section class="day-summary-achievements"><div><MudIcon Icon="@Icons.Material.Filled.EmojiEvents" /><span>Osiągnięcia</span></div>@foreach (var item in day.Achievements) { <strong>@item</strong> }</section> }
        </div>
    };

    private RenderFragment Metric(string label, string value, string note) => __builder => { <div><span>@label</span><strong>@value</strong><small>@note</small></div> };
    private RenderFragment ToolLink(string href, string icon, string title, string note) => __builder => { <a href="@href"><MudIcon Icon="@icon" /><div><strong>@title</strong><span>@note</span></div><MudIcon Icon="@Icons.Material.Outlined.ChevronRight" /></a> };
    private int CalendarOffset => _nutrition is null ? 0 : (7 + (int)_nutrition.Days[0].Date.DayOfWeek - (int)_weekStartsOn) % 7;
    private int MonthOffset(DateOnly date) => (7 + (int)date.DayOfWeek - (int)_weekStartsOn) % 7;
    private IEnumerable<string> CalendarLabels => Enumerable.Range(0, 7).Select(i => ShortDay((DayOfWeek)(((int)_weekStartsOn + i) % 7)));
    private string TabClass(int tab) => _tab == tab ? "active" : string.Empty;
    private static string DateLabel(DateOnly from, DateOnly to) => from.Year == to.Year && from.Month == to.Month ? $"{from.Day}–{to.ToString("d MMMM yyyy", Pl)}" : $"{from.ToString("d MMM", Pl)} – {to.ToString("d MMM yyyy", Pl)}";
    private static string DayClass(NutritionAdherencePoint day) => $"{(day.HasCompletedWorkout ? "workout-done" : null)} {(!day.HasMeals || day.TargetKcal is null ? "diet-empty" : day.IsWithinTarget ? "diet-on" : day.ConsumedKcal < day.TargetKcal ? "diet-under" : "diet-over")}";
    private static string DayStatus(NutritionAdherencePoint day) => !day.HasMeals ? "brak wpisów" : day.IsWithinTarget ? "w zakresie" : day.ConsumedKcal < day.TargetKcal ? "poniżej celu" : "powyżej celu";
    private static string ShortDay(DayOfWeek day) => day switch { DayOfWeek.Monday => "Pn", DayOfWeek.Tuesday => "Wt", DayOfWeek.Wednesday => "Śr", DayOfWeek.Thursday => "Cz", DayOfWeek.Friday => "Pt", DayOfWeek.Saturday => "So", _ => "Nd" };
    private static string Signed(decimal? value) => value is null ? "—" : $"{(value > 0 ? "+" : null)}{value:0.##}";
    private static string Duration(int minutes) => minutes < 60 ? $"{minutes} min" : $"{minutes / 60} h {minutes % 60} min";
    private static string PercentWidth(decimal value) => $"{Math.Clamp(value, 0, 100):0.#}%";
    private static string Invariant(decimal value) => value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
    private void ToggleBodyMetric(string key) { if (!_visibleBodyMetrics.Remove(key)) _visibleBodyMetrics.Add(key); else if (_visibleBodyMetrics.Count == 0) _visibleBodyMetrics.Add(key); }
    private double[] BodyMetricData(string key) => _measurements.Select(x => (double)(key switch { "waist" => x.WaistCm, "chest" => x.ChestCm, "hips" => x.HipsCm, "arm" => x.ArmCm, _ => x.ThighCm } ?? 0)).ToArray();
    private static string MuscleName(string name) => name switch { "Chest" => "Klatka piersiowa", "Back" => "Plecy", "Shoulders" => "Barki", "Biceps" => "Biceps", "Triceps" => "Triceps", "Quadriceps" => "Czworogłowe", "Hamstrings" => "Dwugłowe uda", "Glutes" => "Pośladki", "Calves" => "Łydki", "Core" => "Brzuch", _ => "Całe ciało" };
}
