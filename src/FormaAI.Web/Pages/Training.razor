@page "/training"
@inject AccountClient Account
@inject TrainingClient TrainingApi
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Trening · FormaAI</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="content-wrap module-page training-page">
    <header class="module-heading">
        <div>
            <span class="page-kicker">Plan tygodnia</span>
            <MudText Typo="Typo.h4">Trening</MudText>
            <p>Ułóż rytm tygodnia, a podczas sesji skup się już tylko na kolejnej serii.</p>
        </div>
        <div class="module-heading-actions">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Add" OnClick="StartNewPlan">Nowy plan</MudButton>
            <MudButton Href="/assistant?prompt=Chcę utworzyć nowy plan treningowy. Przeprowadź mnie przez krótką rozmowę, przygotuj kompletny plan do sprawdzenia i zapisz go dopiero po moim zatwierdzeniu." Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.AutoAwesome">Ułóż z AI</MudButton>
        </div>
    </header>
    @if (_loading) { <PageSkeleton Message="Wczytuję plan" Compact="true" /> }
    else
    {
        @if (_activeSession is not null)
        {
            <MudAlert Severity="Severity.Info" Class="mt-3">
                Masz rozpoczęty trening „@_activeSession.Name”. Zapisane serie czekają na Ciebie.
                <MudButton Href="@($"/workout/{_activeSession.Id}")" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="ml-2">Wznów trening</MudButton>
            </MudAlert>
        }

        @if (_today is not null)
        {
            <MudPaper Class="workout-today" Elevation="1">
                <div class="card-heading">
                    <div><span class="card-kicker">Dzisiaj · @_today.PlanName</span><MudText Typo="Typo.h5">@_today.DayName</MudText></div>
                    <span class="data-chip">@_today.Exercises.Count ćwiczeń</span>
                </div>
                @if (!_today.AlreadyCompleted)
                {
                    <div class="workout-length-picker" role="group" aria-label="Długość treningu">
                        <button class="@(_workoutMinutes is null ? "selected" : null)" @onclick="() => _workoutMinutes = null"><strong>Pełny</strong><span>cały plan</span></button>
                        <button class="@(_workoutMinutes == 30 ? "selected" : null)" @onclick="() => _workoutMinutes = 30"><strong>30 min</strong><span>4 ćwiczenia</span></button>
                        <button class="@(_workoutMinutes == 15 ? "selected" : null)" @onclick="() => _workoutMinutes = 15"><strong>15 min</strong><span>minimum dnia</span></button>
                    </div>
                }
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Disabled="_today.AlreadyCompleted" OnClick="Start" Class="mt-3">
                    @(_today.AlreadyCompleted ? "Trening wykonany" : "Rozpocznij trening")
                </MudButton>
                @if (!_today.AlreadyCompleted)
                {
                    <details class="schedule-options"><summary>Nie możesz dzisiaj?</summary><div><MudDatePicker @bind-Date="_moveDate" Label="Przenieś na dzień" MinDate="DateTime.Today.AddDays(1)" /><MudButton Variant="Variant.Outlined" OnClick="MoveWorkout">Przenieś trening</MudButton><MudButton Variant="Variant.Text" Color="Color.Error" OnClick="SkipWorkout">Pomiń świadomie</MudButton></div></details>
                }
            </MudPaper>
        }
        else
        {
            <div class="module-empty training-empty"><MudIcon Icon="@Icons.Material.Outlined.SelfImprovement" /><div><strong>Dziś nie ma przypisanej sesji</strong><span>To może być dzień regeneracji albo moment na aktywowanie planu.</span></div></div>
        }

        <MudTabs @bind-ActivePanelIndex="_activeTab" Class="module-tabs mt-4" PanelClass="food-panel">
            <MudTabPanel Text="Plany">
                <div class="tab-section-heading"><div><span class="card-kicker">Twoje plany</span><h2>Plany treningowe</h2></div><MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Add" OnClick="StartNewPlan">Dodaj nowy plan</MudButton></div>
                @if (_plans.Count == 0)
                {
                    <div class="module-empty"><MudIcon Icon="@Icons.Material.Outlined.EventNote" /><div><strong>Nie masz jeszcze planu</strong><span>Dodaj pierwszy plan i przejdź przez cztery krótkie kroki.</span></div></div>
                }
                <div class="training-plan-list">
                    @foreach (var plan in _plans)
                    {
                        <MudPaper Class="@($"plan-card {(plan.IsActive ? "is-active" : null)}")" Elevation="0">
                            <header class="plan-card-header">
                                <div class="plan-card-identity">
                                    <span class="plan-card-status">@(plan.IsActive ? "Plan aktywny" : "Plan zapisany")</span>
                                    <div class="row-copy"><MudText Typo="Typo.h6">@plan.Name</MudText><MudText Typo="Typo.body2">@plan.Days.Count dni · @plan.Goal</MudText></div>
                                </div>
                                <div class="plan-actions" aria-label="Akcje planu @plan.Name">
                                    @if (!plan.IsActive)
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" OnClick="() => Activate(plan.Id)">Aktywuj</MudButton>
                                    }
                                    <MudIconButton Icon="@Icons.Material.Outlined.Edit" Size="Size.Small" OnClick="() => EditPlan(plan)" aria-label="@($"Edytuj plan {plan.Name}")" />
                                    <MudIconButton Icon="@Icons.Material.Outlined.ContentCopy" Size="Size.Small" OnClick="() => DuplicatePlan(plan)" aria-label="@($"Duplikuj plan {plan.Name}")" />
                                </div>
                            </header>
                            <div class="plan-day-grid">
                                @foreach (var day in plan.Days.OrderBy(x => x.SequenceNumber))
                                {
                                    var dayIndex = plan.Days.OrderBy(x => x.SequenceNumber).ToList().IndexOf(day);
                                    <details class="plan-day-card">
                                        <summary>
                                            <span class="plan-day-number">@day.SequenceNumber</span>
                                            <span class="plan-day-copy"><strong>@day.Name</strong><small>@(day.DayOfWeek is null ? "Rotacyjnie" : DayName(day.DayOfWeek.Value)) · @day.Exercises.Count ćwiczeń</small></span>
                                            <MudIcon Icon="@Icons.Material.Outlined.ExpandMore" />
                                        </summary>
                                        <div class="plan-day-exercises">
                                            @foreach (var exercise in day.Exercises)
                                            {
                                                <div><strong>@exercise.ExerciseName</strong><span>@exercise.Sets serie · @exercise.MinReps-@exercise.MaxReps powt.</span></div>
                                            }
                                        </div>
                                        <MudButton Size="Size.Small" Variant="Variant.Text" StartIcon="@Icons.Material.Outlined.Edit" OnClick="() => EditPlanDay(plan, dayIndex)">Edytuj dzień</MudButton>
                                    </details>
                                }
                            </div>
                        </MudPaper>
                    }
                </div>
            </MudTabPanel>

            <MudTabPanel Text="Nowy plan">
                <section class="module-form training-form">
                    <div class="module-form-heading"><span class="card-kicker">Kreator planu</span><h2>@(_editingPlanId is null ? "Ułóż tydzień krok po kroku" : "Edytuj plan krok po kroku")</h2><p>Najpierw ustal cel, potem zbuduj każdy dzień i sprawdź całość przed zapisaniem.</p></div>
                    @if (_editingPlanId is null)
                    {
                        <MudButton Href="/assistant?prompt=Pomóż mi stworzyć nowy plan treningowy. Zapytaj o cel, liczbę dni, dostępny sprzęt i ograniczenia, a potem pokaż gotowy plan do zatwierdzenia." Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AutoAwesome" Class="plan-ai-entry">Wygeneruj nowy plan z AI</MudButton>
                    }
                    <div class="plan-stepper" aria-label="Etapy tworzenia planu">
                        @for (var step = 1; step <= 4; step++)
                        {
                            <div class="plan-step @StepClass(step)"><span>@step</span><small>@StepName(step)</small></div>
                        }
                    </div>

                    <div class="builder-stage plan-step-card">
                        @if (_planStep == 1)
                        {
                            <span class="card-kicker">Krok 1 z 4 · Podstawy</span>
                            <h3>Nazwij plan i określ jego cel</h3>
                            <p class="step-lead">Ta nazwa będzie widoczna na pulpicie i podczas każdego treningu.</p>
                            <MudTextField @bind-Value="_plan.Name" Label="Nazwa planu" Required="true" />
                            <MudTextField @bind-Value="_plan.Goal" Label="Cel planu" HelperText="Np. siła, masa mięśniowa albo powrót do regularności" Lines="2" MaxLength="500" />
                            <div class="builder-actions end"><MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(string.IsNullOrWhiteSpace(_plan.Name))" OnClick="NextToDay">Dalej · dodaj dzień</MudButton></div>
                        }
                        else if (_planStep == 2)
                        {
                            <span class="card-kicker">Krok 2 z 4 · Dzień treningowy</span>
                            <h3>@(_editingDayIndex is not null ? "Edytuj dzień" : _plan.Days.Count == 0 ? "Zaplanuj pierwszy dzień" : "Dodaj kolejny dzień")</h3>
                            <p class="step-lead">Nadaj mu prostą nazwę, którą rozpoznasz w trakcie tygodnia.</p>
                            @if (_plan.Days.Count > 0) { <div class="draft-count">W planie: <strong>@_plan.Days.Count</strong> @DayCountLabel(_plan.Days.Count)</div> }
                            <MudTextField @bind-Value="_day.Name" Label="Nazwa dnia" Placeholder="Np. Góra ciała A" Required="true" />
                            <MudSelect T="DayOfWeek?" @bind-Value="_day.DayOfWeek" Label="Dzień tygodnia" Clearable="true" HelperText="Możesz zostawić puste, jeśli treningi robisz rotacyjnie">
                                @foreach (var day in Enum.GetValues<DayOfWeek>()) { <MudSelectItem T="DayOfWeek?" Value="@((DayOfWeek?)day)">@DayName(day)</MudSelectItem> }
                            </MudSelect>
                            <div class="builder-actions"><MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Outlined.ArrowBack" OnClick="BackFromDay">Wstecz</MudButton><MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(string.IsNullOrWhiteSpace(_day.Name))" OnClick="NextToExercises">Dalej · ćwiczenia</MudButton></div>
                        }
                        else if (_planStep == 3)
                        {
                            <span class="card-kicker">Krok 3 z 4 · @_day.Name</span>
                            <h3>Dodaj ćwiczenia w kolejności wykonania</h3>
                            <p class="step-lead">Ustaw serie, zakres powtórzeń, zapas RIR i przerwę. Możesz dodać kilka ćwiczeń jedno po drugim.</p>
                            <MudSelect T="Guid?" @bind-Value="_planned.ExerciseId" Label="Wybierz ćwiczenie" Clearable="true">
                                @foreach (var exercise in _exercises) { <MudSelectItem T="Guid?" Value="@((Guid?)exercise.Id)">@exercise.Name · @EquipmentName(exercise.Equipment)</MudSelectItem> }
                            </MudSelect>
                            @if (SelectedExercise() is { } selected)
                            {
                                <div class="selected-exercise"><div><strong>@selected.Name</strong><span>@MuscleGroupName(selected.MuscleGroup) · @EquipmentName(selected.Equipment)</span></div>@if (!string.IsNullOrWhiteSpace(selected.Description)) { <p>@selected.Description</p> }</div>
                            }
                            <div class="set-grid">
                                <MudNumericField @bind-Value="_planned.Sets" Label="Serie" Min="1" Max="10" />
                                <MudNumericField @bind-Value="_planned.MinReps" Label="Powtórzenia od" Min="1" />
                                <MudNumericField @bind-Value="_planned.MaxReps" Label="Powtórzenia do" Min="1" />
                                <MudNumericField @bind-Value="_planned.Rir" Label="RIR" HelperText="Powtórzenia w zapasie" Min="0m" Max="10m" />
                                <MudNumericField @bind-Value="_planned.RestSeconds" Label="Przerwa między seriami (sek.)" Min="0" Max="3600" />
                            </div>
                            <MudButton Variant="Variant.Outlined" StartIcon="@(_editingExerciseIndex is null ? Icons.Material.Outlined.Add : Icons.Material.Outlined.Save)" Disabled="@(_planned.ExerciseId is null)" OnClick="AddExercise">@(_editingExerciseIndex is null ? "Dodaj do dnia" : "Zapisz zmiany ćwiczenia")</MudButton>
                            @if (_day.Exercises.Count > 0)
                            {
                                <div class="day-exercise-list">
                                    @for (var i = 0; i < _day.Exercises.Count; i++)
                                    {
                                        var index = i;
                                        var exercise = _day.Exercises[index];
                                        <div class="day-exercise-row"><span class="exercise-order">@(index + 1)</span><div><strong>@exercise.Name</strong><small>@exercise.Sets serie · @exercise.MinReps-@exercise.MaxReps powt. · RIR @(exercise.Rir?.ToString("0.#") ?? "brak") · przerwa @(exercise.RestSeconds ?? 0) s</small></div><div class="row-actions"><MudIconButton Icon="@Icons.Material.Outlined.Edit" Size="Size.Small" OnClick="() => EditDraftExercise(index)" aria-label="Edytuj ćwiczenie" /><MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline" Size="Size.Small" OnClick="() => RemoveDraftExercise(index)" aria-label="Usuń ćwiczenie" /></div></div>
                                    }
                                </div>
                            }
                            <div class="builder-actions multi"><MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Outlined.ArrowBack" OnClick="() => _planStep = 2">Wstecz</MudButton><MudButton Variant="Variant.Outlined" Disabled="@(_day.Exercises.Count == 0)" OnClick="() => CommitDay(true)">Zapisz dzień i dodaj następny</MudButton><MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(_day.Exercises.Count == 0)" OnClick="() => CommitDay(false)">Do podsumowania</MudButton></div>
                        }
                        else
                        {
                            <span class="card-kicker">Krok 4 z 4 · Podsumowanie</span>
                            <h3>@_plan.Name</h3>
                            <p class="step-lead">@(_plan.Goal.Length == 0 ? "Plan bez dodatkowego opisu celu." : _plan.Goal)</p>
                            <div class="plan-review">
                                @for (var i = 0; i < _plan.Days.Count; i++)
                                {
                                    var index = i;
                                    var day = _plan.Days[index];
                                    <details class="draft-day plan-day-detail">
                                        <summary><span><strong>Dzień @(index + 1) · @day.Name</strong><small>@(day.DayOfWeek is null ? "Tryb rotacyjny" : DayName(day.DayOfWeek.Value)) · @day.Exercises.Count ćwiczeń · @day.Exercises.Sum(x => x.Sets) serii</small></span><MudIcon Icon="@Icons.Material.Outlined.ExpandMore" /></summary>
                                        <div class="plan-day-exercises">@foreach (var exercise in day.Exercises) { <div><strong>@exercise.Name</strong><span>@exercise.Sets serie · @exercise.MinReps-@exercise.MaxReps powt. · RIR @(exercise.Rir?.ToString("0.#") ?? "brak")</span></div> }</div>
                                        <div class="row-actions"><MudButton Size="Size.Small" StartIcon="@Icons.Material.Outlined.Edit" OnClick="() => EditDraftDay(index)">Edytuj dzień</MudButton><MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline" Size="Size.Small" OnClick="() => RemoveDraftDay(index)" aria-label="Usuń dzień" /></div>
                                    </details>
                                }
                            </div>
                            <div class="builder-actions multi"><MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Outlined.Add" OnClick="AddAnotherDay">Dodaj kolejny dzień</MudButton><MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(_plan.Days.Count == 0)" OnClick="SavePlan">@(_editingPlanId is null ? "Zapisz i aktywuj plan" : "Zapisz zmiany planu")</MudButton></div>
                        }
                    </div>
                </section>
            </MudTabPanel>

            <MudTabPanel Text="Ćwiczenia">
                <div class="tab-section-heading"><div><span class="card-kicker">Biblioteka</span><h2>Ćwiczenia</h2></div><MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Add" OnClick="StartNewExercise">Dodaj ćwiczenie</MudButton></div>
                <div class="exercise-index">
                    @foreach (var exercise in _exercises)
                    {
                        <article class="exercise-card"><div><strong>@exercise.Name</strong>@if (exercise.IsOwn) { <div class="exercise-card-actions"><small>Własne</small><MudIconButton Icon="@Icons.Material.Outlined.Edit" Size="Size.Small" OnClick="() => EditLibraryExercise(exercise)" aria-label="Edytuj własne ćwiczenie" /></div> }</div><span>@EngagementLabel(exercise) · @EquipmentName(exercise.Equipment)</span>@if (!string.IsNullOrWhiteSpace(exercise.Description)) { <p>@exercise.Description</p> }</article>
                    }
                </div>
            </MudTabPanel>

            <MudTabPanel Text="Nowe ćwiczenie">
                <section class="module-form training-form">
                    <div class="module-form-heading"><span class="card-kicker">Kreator ćwiczenia</span><h2>@(_editingLibraryExerciseId is null ? "Dodaj ćwiczenie krok po kroku" : "Edytuj ćwiczenie krok po kroku")</h2><p>Najpierw nazwij ruch, potem wybierz sprzęt i na końcu rozpisz pracę partii mięśniowych.</p></div>
                    <div class="plan-stepper exercise-stepper" aria-label="Etapy tworzenia ćwiczenia">
                        @for (var step = 1; step <= 3; step++)
                        {
                            <div class="plan-step @ExerciseStepClass(step)"><span>@step</span><small>@ExerciseStepName(step)</small></div>
                        }
                    </div>
                    <div class="builder-stage plan-step-card">
                        @if (_exerciseStep == 1)
                        {
                            <span class="card-kicker">Krok 1 z 3 · Podstawy</span><h3>Nazwa i wskazówki</h3><p class="step-lead">Użyj nazwy, którą łatwo rozpoznasz później w planie.</p>
                            <MudTextField @bind-Value="_custom.Name" Label="Nazwa ćwiczenia" Required="true" />
                            <MudTextField @bind-Value="_custom.Description" Label="Opis i wskazówki wykonania" Placeholder="Np. ustaw ławkę pod kątem 30°, łopatki trzymaj ściągnięte" Lines="3" MaxLength="1000" />
                            <div class="builder-actions"><MudButton Variant="Variant.Text" OnClick="CancelExerciseEdit">Anuluj</MudButton><MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(string.IsNullOrWhiteSpace(_custom.Name))" OnClick="() => _exerciseStep = 2">Dalej · sprzęt</MudButton></div>
                        }
                        else if (_exerciseStep == 2)
                        {
                            <span class="card-kicker">Krok 2 z 3 · Wykonanie</span><h3>Sprzęt i rodzaj ruchu</h3><p class="step-lead">Te dane pomagają dobrać ćwiczenie podczas układania planu.</p>
                            <MudSelect T="Equipment" @bind-Value="_custom.Equipment" Label="Sprzęt / rodzaj obciążenia" HelperText="@EquipmentKind(_custom.Equipment)">@foreach (var equipment in Enum.GetValues<Equipment>()) { <MudSelectItem Value="@equipment">@EquipmentName(equipment)</MudSelectItem> }</MudSelect>
                            <MudCheckBox @bind-Value="_custom.IsUnilateral" Label="Ćwiczenie jednostronne" />
                            <div class="builder-actions"><MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Outlined.ArrowBack" OnClick="() => _exerciseStep = 1">Wstecz</MudButton><MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => _exerciseStep = 3">Dalej · partie mięśniowe</MudButton></div>
                        }
                        else
                        {
                            <span class="card-kicker">Krok 3 z 3 · Partie mięśniowe</span><h3>Jak rozkłada się praca?</h3><p class="step-lead">Rozdziel 100% zaangażowania pomiędzy maksymalnie pięć partii.</p>
                            <section class="muscle-engagement-editor">
                                <div class="muscle-engagement-heading"><div><strong>Zaangażowanie partii</strong><span>Ustal udział pracy każdej partii w tym ćwiczeniu.</span></div><span class="@(EngagementTotal == 100 ? "complete" : null)">Razem @EngagementTotal%</span></div>
                                @for (var i = 0; i < _custom.Engagements.Count; i++)
                                {
                                    var index = i; var row = _custom.Engagements[index];
                                    <div class="muscle-engagement-row"><MudSelect T="MuscleGroup" Value="row.MuscleGroup" ValueChanged="group => ChangeEngagementGroup(index, group)" Label="Partia">@foreach (var group in Enum.GetValues<MuscleGroup>()) { <MudSelectItem Value="@group" Disabled="@GroupUsedByOtherRow(group, index)">@MuscleGroupName(group)</MudSelectItem> }</MudSelect><MudNumericField T="int" Value="row.Percentage" ValueChanged="value => ChangeEngagementPercentage(index, value)" Label="Udział %" Min="1" Max="100" /><MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline" Disabled="@(_custom.Engagements.Count == 1)" OnClick="() => RemoveEngagement(index)" aria-label="Usuń partię" /></div>
                                }
                                <div class="muscle-engagement-footer"><span>@(EngagementRemaining == 0 ? "Suma jest prawidłowa" : EngagementRemaining > 0 ? $"Pozostało {EngagementRemaining}%" : $"Przekroczono o {-EngagementRemaining}%")</span><MudButton Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Outlined.Add" Disabled="@(_custom.Engagements.Count >= 5)" OnClick="AddEngagement">Dodaj partię</MudButton></div>
                            </section>
                            <div class="builder-actions"><MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Outlined.ArrowBack" OnClick="() => _exerciseStep = 2">Wstecz</MudButton><MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(EngagementTotal != 100)" OnClick="SaveExercise">@(_editingLibraryExerciseId is null ? "Zapisz ćwiczenie" : "Zapisz zmiany")</MudButton></div>
                        }
                    </div>
                </section>
            </MudTabPanel>
        </MudTabs>
    }
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "new")] public string? NewQuery { get; set; }

    private IReadOnlyList<ExerciseResponse> _exercises = [];
    private IReadOnlyList<TrainingPlanResponse> _plans = [];
    private TodayWorkoutResponse? _today;
    private WorkoutSessionResponse? _activeSession;
    private readonly PlanDraft _plan = new();
    private readonly DayDraft _day = new();
    private readonly PlannedDraft _planned = new();
    private readonly ExerciseDraft _custom = new();
    private bool _loading = true;
    private int _activeTab;
    private int _planStep = 1;
    private int _exerciseStep = 1;
    private Guid? _editingPlanId;
    private int? _editingDayIndex;
    private int? _editingExerciseIndex;
    private Guid? _editingLibraryExerciseId;
    private int? _workoutMinutes;
    private DateTime? _moveDate = DateTime.Today.AddDays(1);

    protected override async Task OnInitializedAsync()
    {
        if (await Account.GetCurrentUser() is null) { Navigation.NavigateTo("/"); return; }
        var profile = await Account.GetProfile();
        _planned.Sets = profile.DefaultSets;
        _planned.MinReps = profile.DefaultRepetitions;
        _planned.MaxReps = profile.DefaultRepetitions;
        _planned.RestSeconds = profile.DefaultRestSeconds;
        await Reload();
        if (NewQuery?.Equals("plan", StringComparison.OrdinalIgnoreCase) == true)
            StartNewPlan();
        _loading = false;
    }
    private async Task Reload() { _exercises = await TrainingApi.GetExercises(); _plans = await TrainingApi.GetPlans(); _today = await TrainingApi.GetToday(); _activeSession = await TrainingApi.GetActiveSession(); }
    private void AddExercise()
    {
        var exercise = _exercises.FirstOrDefault(x => x.Id == _planned.ExerciseId);
        if (exercise is null) return;
        if (_planned.MinReps > _planned.MaxReps)
        {
            Snackbar.Add("Dolna granica powtórzeń nie może być większa od górnej.", Severity.Warning);
            return;
        }
        var item = new PlannedDraftItem(exercise.Id, exercise.Name, _planned.Sets, _planned.MinReps, _planned.MaxReps, _planned.Rir, _planned.RestSeconds);
        if (_editingExerciseIndex is int index) _day.Exercises[index] = item;
        else _day.Exercises.Add(item);
        _editingExerciseIndex = null; _planned.ExerciseId = null;
    }

    private void NextToDay() => _planStep = 2;
    private void NextToExercises() => _planStep = 3;
    private void AddAnotherDay() { _editingDayIndex = null; _planStep = 2; }
    private void BackFromDay() => _planStep = _editingDayIndex is null ? 1 : 4;
    private ExerciseResponse? SelectedExercise() => _exercises.FirstOrDefault(x => x.Id == _planned.ExerciseId);
    private void StartNewPlan()
    {
        _editingPlanId = null; _editingDayIndex = null; _editingExerciseIndex = null;
        _plan.Name = "Mój plan"; _plan.Goal = string.Empty; _plan.StartsOn = DateOnly.FromDateTime(DateTime.Today); _plan.Days.Clear();
        _day.Name = string.Empty; _day.DayOfWeek = null; _day.Exercises.Clear(); _planStep = 1; _activeTab = 1;
    }

    private void StartNewExercise()
    {
        ResetExerciseDraft();
        _activeTab = 3;
    }

    private void EditPlan(TrainingPlanResponse plan)
    {
        _editingPlanId = plan.Id; _plan.Name = plan.Name; _plan.Goal = plan.Goal; _plan.StartsOn = plan.StartsOn; _plan.Days.Clear();
        foreach (var day in plan.Days.OrderBy(x => x.SequenceNumber))
            _plan.Days.Add(new DayDraftItem(day.Name, day.DayOfWeek, day.Exercises.Select(x => new PlannedDraftItem(x.ExerciseId, x.ExerciseName, x.Sets, x.MinReps, x.MaxReps, x.TargetRir, x.RestSeconds)).ToList()));
        _editingDayIndex = null; _editingExerciseIndex = null; _planStep = 4; _activeTab = 1;
    }

    private void EditPlanDay(TrainingPlanResponse plan, int dayIndex)
    {
        EditPlan(plan);
        EditDraftDay(dayIndex);
    }

    private async Task DuplicatePlan(TrainingPlanResponse plan)
    {
        var request = new SaveTrainingPlanRequest($"{plan.Name} · kopia", plan.Goal, DateOnly.FromDateTime(DateTime.Today),
            plan.Days.OrderBy(x => x.SequenceNumber).Select(day => new TrainingDayRequest(day.Name, day.DayOfWeek,
                day.Exercises.Select(x => new PlannedExerciseRequest(x.ExerciseId, x.Sets, x.MinReps, x.MaxReps, x.TargetRir, x.RestSeconds)).ToList())).ToList());
        await TrainingApi.SavePlan(request);
        await Reload();
        Snackbar.Add("Utworzono kopię planu do dalszej edycji.", Severity.Success);
    }

    private void EditDraftDay(int index)
    {
        var day = _plan.Days[index];
        _day.Name = day.Name; _day.DayOfWeek = day.DayOfWeek; _day.Exercises.Clear(); _day.Exercises.AddRange(day.Exercises);
        _editingDayIndex = index; _editingExerciseIndex = null; _planStep = 2;
    }

    private void EditDraftExercise(int index)
    {
        var exercise = _day.Exercises[index];
        _planned.ExerciseId = exercise.ExerciseId; _planned.Sets = exercise.Sets; _planned.MinReps = exercise.MinReps;
        _planned.MaxReps = exercise.MaxReps; _planned.Rir = exercise.Rir; _planned.RestSeconds = exercise.RestSeconds; _editingExerciseIndex = index;
    }

    private void CommitDay(bool addAnother)
    {
        if (_day.Exercises.Count == 0) return;
        if (_day.DayOfWeek is not null && _plan.Days.Where((_, i) => i != _editingDayIndex).Any(x => x.DayOfWeek == _day.DayOfWeek))
        {
            Snackbar.Add("Ten dzień tygodnia jest już użyty w planie.", Severity.Warning);
            return;
        }
        var day = new DayDraftItem(_day.Name.Trim(), _day.DayOfWeek, [.. _day.Exercises]);
        if (_editingDayIndex is int index) _plan.Days[index] = day;
        else _plan.Days.Add(day);
        _day.Name = string.Empty; _day.DayOfWeek = null; _day.Exercises.Clear();
        _editingDayIndex = null; _editingExerciseIndex = null;
        _planStep = addAnother ? 2 : 4;
    }

    private void RemoveDraftExercise(int index) => _day.Exercises.RemoveAt(index);
    private void RemoveDraftDay(int index) => _plan.Days.RemoveAt(index);

    private async Task SavePlan() => await Run(async () =>
    {
        var request = new SaveTrainingPlanRequest(_plan.Name, _plan.Goal, _plan.StartsOn, _plan.Days.Select(d => new TrainingDayRequest(d.Name, d.DayOfWeek, d.Exercises.Select(x => new PlannedExerciseRequest(x.ExerciseId, x.Sets, x.MinReps, x.MaxReps, x.Rir, x.RestSeconds)).ToList())).ToList());
        var saved = _editingPlanId is Guid id ? await TrainingApi.UpdatePlan(id, request) : await TrainingApi.SavePlan(request);
        await TrainingApi.Activate(saved.Id);
        _editingPlanId = null; _plan.Name = "Mój plan"; _plan.Goal = string.Empty; _plan.StartsOn = DateOnly.FromDateTime(DateTime.Now); _plan.Days.Clear(); _planStep = 1; _activeTab = 0;
        await Reload(); Snackbar.Add("Plan zapisany i aktywowany.", Severity.Success);
    });
    private async Task SaveExercise() => await Run(async () =>
    {
        var rows = _custom.Engagements.Select(x => new ExerciseMuscleEngagementRequest(x.MuscleGroup, x.Percentage)).ToList();
        var primary = _custom.Engagements.OrderByDescending(x => x.Percentage).First().MuscleGroup;
        var request = new SaveExerciseRequest(_custom.Name, primary, _custom.Equipment, _custom.IsUnilateral, _custom.Description, rows);
        if (_editingLibraryExerciseId is Guid id) await TrainingApi.UpdateExercise(id, request);
        else await TrainingApi.SaveExercise(request);
        CancelExerciseEdit(); await Reload(); Snackbar.Add("Ćwiczenie zapisane w bibliotece.", Severity.Success);
    });
    private void EditLibraryExercise(ExerciseResponse exercise)
    {
        _editingLibraryExerciseId = exercise.Id; _custom.Name = exercise.Name; _custom.Description = exercise.Description;
        _custom.Equipment = exercise.Equipment; _custom.IsUnilateral = exercise.IsUnilateral; _custom.Engagements.Clear();
        _custom.Engagements.AddRange((exercise.MuscleEngagements ?? [new(exercise.MuscleGroup, 100)]).Select(x => new EngagementDraft(x.MuscleGroup, x.Percentage)));
        _exerciseStep = 1; _activeTab = 3;
    }
    private void CancelExerciseEdit()
    {
        ResetExerciseDraft();
        _activeTab = 2;
    }
    private void ResetExerciseDraft()
    {
        _editingLibraryExerciseId = null; _exerciseStep = 1; _custom.Name = string.Empty; _custom.Description = string.Empty; _custom.Equipment = Equipment.Bodyweight; _custom.IsUnilateral = false; _custom.Engagements.Clear(); _custom.Engagements.Add(new(MuscleGroup.FullBody, 100));
    }
    private int EngagementTotal => _custom.Engagements.Sum(x => x.Percentage);
    private int EngagementRemaining => 100 - EngagementTotal;
    private void AddEngagement()
    {
        var group = Enum.GetValues<MuscleGroup>().FirstOrDefault(x => _custom.Engagements.All(e => e.MuscleGroup != x));
        _custom.Engagements.Add(new(group, Math.Max(1, EngagementRemaining)));
    }
    private void RemoveEngagement(int index) => _custom.Engagements.RemoveAt(index);
    private void ChangeEngagementGroup(int index, MuscleGroup group) => _custom.Engagements[index].MuscleGroup = group;
    private void ChangeEngagementPercentage(int index, int percentage) => _custom.Engagements[index].Percentage = percentage;
    private bool GroupUsedByOtherRow(MuscleGroup group, int index) => _custom.Engagements.Where((_, i) => i != index).Any(x => x.MuscleGroup == group);
    private static string EngagementLabel(ExerciseResponse exercise) => string.Join(" · ", (exercise.MuscleEngagements ?? [new(exercise.MuscleGroup, 100)]).OrderByDescending(x => x.Percentage).Select(x => $"{MuscleGroupName(x.MuscleGroup)} {x.Percentage}%"));
    private async Task Activate(Guid id) => await Run(async () => { await TrainingApi.Activate(id); await Reload(); });
    private async Task Start() { var session = await TrainingApi.Start(_today!.TrainingDayId, _workoutMinutes); Navigation.NavigateTo($"/workout/{session.Id}"); }
    private async Task MoveWorkout() { if (_moveDate is null || _today is null) return; await TrainingApi.SaveSchedule(new(_today.TrainingDayId, DateOnly.FromDateTime(DateTime.Today), DateOnly.FromDateTime(_moveDate.Value), ScheduleDecision.Moved, "Przeniesiono przez użytkownika")); Snackbar.Add("Trening został przeniesiony.", Severity.Success); await Reload(); }
    private async Task SkipWorkout() { if (_today is null) return; await TrainingApi.SaveSchedule(new(_today.TrainingDayId, DateOnly.FromDateTime(DateTime.Today), null, ScheduleDecision.Skipped, "Pominięto przez użytkownika")); Snackbar.Add("Dzień został oznaczony jako świadomie pominięty.", Severity.Info); await Reload(); }
    private async Task Run(Func<Task> action) { try { await action(); } catch (HttpRequestException) { Snackbar.Add("Nie udało się zapisać zmian.", Severity.Error); } }
    private static string DayName(DayOfWeek day) => day switch { DayOfWeek.Monday => "Poniedziałek", DayOfWeek.Tuesday => "Wtorek", DayOfWeek.Wednesday => "Środa", DayOfWeek.Thursday => "Czwartek", DayOfWeek.Friday => "Piątek", DayOfWeek.Saturday => "Sobota", _ => "Niedziela" };
    private string StepClass(int step) => step == _planStep ? "active" : step < _planStep ? "done" : string.Empty;
    private static string StepName(int step) => step switch { 1 => "Cel", 2 => "Dzień", 3 => "Ćwiczenia", _ => "Sprawdź" };
    private string ExerciseStepClass(int step) => step == _exerciseStep ? "active" : step < _exerciseStep ? "done" : string.Empty;
    private static string ExerciseStepName(int step) => step switch { 1 => "Nazwa", 2 => "Sprzęt", _ => "Partie" };
    private static string DayCountLabel(int count) => count == 1 ? "dzień" : count is 2 or 3 or 4 ? "dni" : "dni";
    private static string EquipmentKind(Equipment equipment) => equipment switch
    {
        Equipment.Barbell or Equipment.Dumbbell or Equipment.Kettlebell => "Wolny ciężar",
        Equipment.Machine => "Maszyna z prowadnicą lub stosem",
        Equipment.Cable => "Wyciąg / stos",
        Equipment.Bodyweight => "Masa własnego ciała",
        _ => "Inny rodzaj sprzętu"
    };
    private static string EquipmentName(Equipment equipment) => equipment switch
    {
        Equipment.Barbell => "Sztanga · wolny ciężar",
        Equipment.Dumbbell => "Hantle · wolny ciężar",
        Equipment.Machine => "Maszyna",
        Equipment.Cable => "Wyciąg",
        Equipment.Bodyweight => "Masa ciała",
        Equipment.Kettlebell => "Kettlebell · wolny ciężar",
        _ => "Inny sprzęt"
    };
    private static string MuscleGroupName(MuscleGroup group) => group switch
    {
        MuscleGroup.Chest => "Klatka piersiowa",
        MuscleGroup.Back => "Plecy",
        MuscleGroup.Shoulders => "Barki",
        MuscleGroup.Biceps => "Biceps",
        MuscleGroup.Triceps => "Triceps",
        MuscleGroup.Quadriceps => "Czworogłowe uda",
        MuscleGroup.Hamstrings => "Dwugłowe uda",
        MuscleGroup.Glutes => "Pośladki",
        MuscleGroup.Calves => "Łydki",
        MuscleGroup.Core => "Brzuch i core",
        _ => "Całe ciało"
    };

    private sealed class PlanDraft { public string Name { get; set; } = "Mój plan"; public string Goal { get; set; } = string.Empty; public DateOnly StartsOn { get; set; } = DateOnly.FromDateTime(DateTime.Now); public List<DayDraftItem> Days { get; } = []; }
    private sealed class DayDraft { public string Name { get; set; } = string.Empty; public DayOfWeek? DayOfWeek { get; set; } public List<PlannedDraftItem> Exercises { get; } = []; }
    private sealed class PlannedDraft { public Guid? ExerciseId { get; set; } public int Sets { get; set; } = 3; public int MinReps { get; set; } = 8; public int MaxReps { get; set; } = 12; public decimal? Rir { get; set; } = 2; public int? RestSeconds { get; set; } = 90; }
    private sealed class ExerciseDraft { public string Name { get; set; } = string.Empty; public string? Description { get; set; } public Equipment Equipment { get; set; } = Equipment.Other; public bool IsUnilateral { get; set; } public List<EngagementDraft> Engagements { get; } = [new(MuscleGroup.FullBody, 100)]; }
    private sealed class EngagementDraft(MuscleGroup muscleGroup, int percentage) { public MuscleGroup MuscleGroup { get; set; } = muscleGroup; public int Percentage { get; set; } = percentage; }
    private sealed record PlannedDraftItem(Guid ExerciseId, string Name, int Sets, int MinReps, int MaxReps, decimal? Rir, int? RestSeconds);
    private sealed record DayDraftItem(string Name, DayOfWeek? DayOfWeek, List<PlannedDraftItem> Exercises);
}
