@page "/food"
@inject AccountClient Account
@inject NutritionClient Nutrition
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Jedzenie · FormaAI</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="content-wrap module-page food-page">
    <header class="module-heading">
        <div>
            <span class="page-kicker">Paliwo · @DayCaption.ToLowerInvariant()</span>
            <MudText Typo="Typo.h4">Jedzenie</MudText>
            <p>Zapisuj posiłki i trzymaj dzienny rytm bez liczenia wszystkiego w pamięci.</p>
        </div>
        <div class="module-heading-actions">
            <MudButton Href="/food/add" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Add">Dodaj posiłek</MudButton>
            <MudButton Href="/food/add?mode=text" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.AutoAwesome">Dodaj z AI</MudButton>
            <MudButton Href="/pantry" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Kitchen">Spiżarnia</MudButton>
        </div>
    </header>

    @if (_loading)
    {
        <PageSkeleton Message="Wczytuję dziennik" Compact="true" />
    }
    else
    {
        <section class="food-week" aria-label="Wybór dnia tygodnia">
            <div class="food-week-heading">
                <div><span>@DayCaption</span><strong>@_date.ToString("d MMMM", PolishCulture)</strong></div>
                <div>
                    <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" OnClick="() => ChangeWeek(-1)" aria-label="Poprzedni tydzień" />
                    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Disabled="@(WeekStart.AddDays(7) > Today)" OnClick="() => ChangeWeek(1)" aria-label="Następny tydzień" />
                </div>
            </div>
            <div class="food-week-days">
                @foreach (var day in WeekDays)
                {
                    <button type="button" class="@(day == _date ? "selected" : null) @(day == Today ? "today" : null)" disabled="@(day > Today)" @onclick="() => SelectDay(day)" aria-label="@day.ToString("dddd, d MMMM", PolishCulture)">
                        <span>@day.ToString("ddd", PolishCulture).TrimEnd('.')</span>
                        <strong>@day.Day</strong>
                        <i aria-hidden="true"></i>
                    </button>
                }
            </div>
        </section>

        <div class="food-panel food-diary @(_dayLoading ? "loading" : null)" aria-busy="@_dayLoading">
                @if (_dayLoading)
                {
                    <div class="food-day-loading"><MudProgressCircular Indeterminate="true" Size="Size.Medium" Color="Color.Primary" /><span>Pobieram podsumowanie dnia…</span></div>
                }
                @if (_day is not null)
                {
                    <MacroSummary Day="_day" />
                    @foreach (var slot in _mealSlots)
                    {
                        var meals = MealsFor(slot);
                        var calories = meals.Sum(x => x.Macro.CaloriesKcal);
                        var protein = meals.Sum(x => x.Macro.ProteinG);
                        var carbs = meals.Sum(x => x.Macro.CarbohydratesG);
                        var fat = meals.Sum(x => x.Macro.FatG);
                        var appearance = MealAppearance(slot);
                        <section class="meal-slot meal-theme-@appearance.Color @(IsMealSlotOpen(slot) ? "open" : null)">
                            <header class="meal-slot-heading">
                                <button type="button" class="meal-slot-toggle" @onclick="() => ToggleMealSlot(slot)" disabled="@(meals.Count == 0)" aria-expanded="@IsMealSlotOpen(slot)">
                                    <MealSlotIcon IconKey="@appearance.Icon" ColorKey="@appearance.Color" />
                                    <span class="meal-slot-copy"><strong>@slot</strong><small>@(meals.Count == 0 ? "Nie dodano produktów" : $"{meals.Count} pozycji")</small></span>
                                </button>
                                <div class="meal-slot-stats" aria-label="Podsumowanie posiłku">
                                    @if (meals.Count > 0)
                                    {
                                        <span class="calories">@calories.ToString("0") kcal</span><span>B @protein.ToString("0.#") g</span><span>W @carbs.ToString("0.#") g</span><span>T @fat.ToString("0.#") g</span>
                                    }
                                    else
                                    {
                                        <time>@appearance.Time.ToString("HH:mm")</time>
                                    }
                                </div>
                                @if (meals.Count == 0)
                                {
                                    <MudIconButton Icon="@Icons.Material.Outlined.Add" OnClick="() => StartMeal(slot)" aria-label="@($"Dodaj do sekcji {slot}")" />
                                }
                                else
                                {
                                    <MudIconButton Icon="@(IsMealSlotOpen(slot) ? Icons.Material.Filled.KeyboardArrowUp : Icons.Material.Filled.KeyboardArrowDown)" OnClick="() => ToggleMealSlot(slot)" aria-label="@($"Pokaż lub ukryj sekcję {slot}")" />
                                }
                            </header>
                            @if (meals.Count > 0 && IsMealSlotOpen(slot))
                            {
                                @foreach (var meal in meals)
                                {
                                    <MudPaper Class="meal-row" Elevation="0">
                                        <div class="row-copy">
                                            <MudText Typo="Typo.subtitle1">@DisplayMealName(meal.Name, slot)</MudText>
                                            <MudText Typo="Typo.caption">@string.Join(" · ", meal.Items.Select(x => $"{x.ProductName} {x.AmountGrams:0.#} g"))</MudText>
                                        </div>
                                        <div class="meal-actions">
                                            <MudText Typo="Typo.body2">@meal.Macro.CaloriesKcal.ToString("0") kcal</MudText>
                                            <MudIconButton Icon="@Icons.Material.Outlined.ContentCopy" Size="Size.Small" OnClick="() => CopyMeal(meal)" aria-label="Kopiuj posiłek" />
                                            <MudIconButton Icon="@Icons.Material.Outlined.Edit" Size="Size.Small" OnClick="() => EditMeal(meal, slot)" aria-label="Edytuj posiłek" />
                                            <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteMeal(meal.Id)" aria-label="Usuń posiłek" />
                                        </div>
                                    </MudPaper>
                                }
                                <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Outlined.Add" OnClick="() => StartMeal(slot)" Class="meal-slot-add">Dodaj produkt</MudButton>
                            }
                        </section>
                    }
                    @if (UnassignedMeals.Count > 0)
                    {
                        <section class="meal-slot meal-slot-unassigned">
                            <header class="meal-slot-heading">
                                <div><strong>Pozostałe wpisy</strong><span>@UnassignedMeals.Count pozycji · @UnassignedMeals.Sum(x => x.Macro.CaloriesKcal).ToString("0") kcal</span><span class="meal-slot-macros">Wpisy zapisane bez przypisanej sekcji posiłku</span></div>
                            </header>
                            @foreach (var meal in UnassignedMeals)
                            {
                                <MudPaper Class="meal-row" Elevation="0">
                                    <div class="row-copy">
                                        <MudText Typo="Typo.subtitle1">@meal.Name</MudText>
                                        <MudText Typo="Typo.caption">@string.Join(" · ", meal.Items.Select(x => $"{x.ProductName} {x.AmountGrams:0.#} g"))</MudText>
                                    </div>
                                    <div class="meal-actions">
                                        <MudText Typo="Typo.body2">@meal.Macro.CaloriesKcal.ToString("0") kcal</MudText>
                                        <MudIconButton Icon="@Icons.Material.Outlined.ContentCopy" Size="Size.Small" OnClick="() => CopyMeal(meal)" aria-label="Kopiuj posiłek" />
                                        <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteMeal(meal.Id)" aria-label="Usuń posiłek" />
                                    </div>
                                </MudPaper>
                            }
                        </section>
                    }
                    <MudButton Variant="Variant.Outlined" FullWidth="true" StartIcon="@Icons.Material.Outlined.Restore" OnClick="CopyPreviousDay" Class="mt-3">Kopiuj posiłki z poprzedniego dnia</MudButton>
                    <section class="day-close-card">
                        <div>
                            <span class="card-kicker">Jakość danych</span>
                            <h3>@DayStatusTitle</h3>
                            <p>Oznacz dzień świadomie. Jeden posiłek nie oznacza jeszcze kompletnego dziennika.</p>
                        </div>
                        <div class="day-close-actions">
                            <MudButton Variant="@StatusVariant(NutritionDayStatus.Unknown)" Color="Color.Primary" OnClick="() => SetDayStatus(NutritionDayStatus.Unknown)">Niezdecydowano</MudButton>
                            <MudButton Variant="@StatusVariant(NutritionDayStatus.Complete)" Color="Color.Success" OnClick="() => SetDayStatus(NutritionDayStatus.Complete)">Dziennik kompletny</MudButton>
                            <MudButton Variant="@StatusVariant(NutritionDayStatus.Partial)" Color="Color.Warning" OnClick="() => SetDayStatus(NutritionDayStatus.Partial)">Zapisałem część</MudButton>
                            <MudButton Variant="@StatusVariant(NutritionDayStatus.NoData)" Color="Color.Default" OnClick="() => SetDayStatus(NutritionDayStatus.NoData)">Brak danych</MudButton>
                        </div>
                    </section>
                }
        </div>

            @if (ShowInlineMealEditor)
            {
            <MudTabPanel Text="Dodaj posiłek">
                @if (_recentMeals.Count > 0)
                {
                    <section class="recent-meals">
                        <div class="module-form-heading"><span class="card-kicker">Ostatnie i szablony</span><h2>Dodaj ponownie</h2><p>Najczęściej powtarzane posiłki są gotowe bez ponownego wpisywania składników.</p></div>
                        <div class="recent-meal-grid">
                            @foreach (var recent in _recentMeals)
                            {
                                <button type="button" @onclick="() => CopyMeal(recent)"><strong>@recent.Name</strong><span>@recent.Macro.CaloriesKcal.ToString("0") kcal · B @recent.Macro.ProteinG.ToString("0") g</span></button>
                            }
                        </div>
                    </section>
                }
                <section class="module-form fuel-form">
                    <div class="module-form-heading">
                        <span class="card-kicker">Nowy wpis</span>
                        <h2>Zbuduj posiłek</h2>
                        <p>Dodaj ręcznie albo pozwól AI oszacować skład ze zdjęcia lub opisu.</p>
                    </div>
                    <div class="meal-entry-modes" role="group" aria-label="Sposób dodawania posiłku">
                        <MudButton Variant="@(_entryMode == MealEntryMode.Manual ? Variant.Filled : Variant.Text)" Color="Color.Primary" OnClick="() => SelectMode(MealEntryMode.Manual)" StartIcon="@Icons.Material.Outlined.Edit">Ręcznie</MudButton>
                        <MudButton Variant="@(_entryMode == MealEntryMode.Photo ? Variant.Filled : Variant.Text)" Color="Color.Primary" OnClick="() => SelectMode(MealEntryMode.Photo)" StartIcon="@Icons.Material.Outlined.PhotoCamera">Zdjęcie AI</MudButton>
                        <MudButton Variant="@(_entryMode == MealEntryMode.Text ? Variant.Filled : Variant.Text)" Color="Color.Primary" OnClick="() => SelectMode(MealEntryMode.Text)" StartIcon="@Icons.Material.Outlined.AutoAwesome">Opis AI</MudButton>
                    </div>
                    <MudSelect T="string" @bind-Value="_selectedMealSlot" Label="Sekcja dziennika">
                        @foreach (var slot in _mealSlots) { <MudSelectItem Value="@slot">@slot</MudSelectItem> }
                    </MudSelect>

                    @if (_entryMode == MealEntryMode.Manual)
                    {
                    @if (_editingMealId is not null) { <MudAlert Severity="Severity.Info" Dense="true">Edytujesz zapisany posiłek. Zapis zastąpi poprzednią wersję.</MudAlert> }
                    <MudTextField @bind-Value="_meal.Name" Label="Nazwa dania (opcjonalnie)" />
                    <MudTextField @bind-Value="_productSearch" Immediate="true" Label="Szukaj produktu" Placeholder="Wpisz nazwę lub markę" />
                    <MudSelect T="Guid?" Value="_meal.ProductId" ValueChanged="SelectProduct" Label="Produkt">
                        @foreach (var product in FilteredProducts)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)product.Id)">@product.Name</MudSelectItem>
                        }
                    </MudSelect>
                    <MudNumericField @bind-Value="_meal.AmountGrams" Label="Ilość (g)" Min="0.01m" />
                    <div class="portion-shortcuts">
                        <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="() => ScalePortion(.5m)">½ porcji</MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="() => ScalePortion(1m)">1 porcja</MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="() => ScalePortion(2m)">2 porcje</MudButton>
                    </div>
                    <MudButton Variant="Variant.Outlined" OnClick="AddItem" Class="mt-2">Dodaj pozycję</MudButton>

                    @if (_meal.Items.Count > 0)
                    {
                        <div class="draft-chips">
                            @foreach (var item in _meal.Items)
                            {
                                <MudChip T="string">@item.Name · @item.AmountGrams.ToString("0.#") g</MudChip>
                            }
                        </div>
                    }

                    <MudCheckBox @bind-Value="_meal.DeductFromPantry" Label="Odejmij składniki ze spiżarni" />

                    <div class="builder-actions end mt-4">
                        @if (_editingMealId is not null) { <MudButton Variant="Variant.Text" OnClick="CancelMealEdit">Anuluj edycję</MudButton> }
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(_meal.Items.Count == 0)" OnClick="SaveMeal">@(_editingMealId is null ? "Zapisz posiłek" : "Zapisz zmiany")</MudButton>
                    </div>
                    }
                    else
                    {
                        @if (_entryMode == MealEntryMode.Photo)
                        {
                            <label class="meal-photo-capture @(_aiBusy ? "busy" : null)">
                                <MudIcon Icon="@Icons.Material.Outlined.PhotoCamera" />
                                <strong>@(_aiBusy ? "AI analizuje zdjęcie…" : "Zrób zdjęcie jedzenia")</strong>
                                <span>Na iPhonie otworzy się aparat. Możesz też wybrać zdjęcie z galerii.</span>
                                <InputFile OnChange="AnalyzePhoto" accept="image/jpeg,image/png,image/webp,image/heic,image/heif" capture="environment" disabled="@_aiBusy" />
                            </label>
                        }
                        else
                        {
                            <MudTextField @bind-Value="_mealDescription" Immediate="true" Label="Co zjadłeś?" Lines="4" MaxLength="1000" Placeholder="Np. dwa jajka sadzone, dwie kromki chleba z masłem i pomidor" />
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Disabled="@(_aiBusy || string.IsNullOrWhiteSpace(_mealDescription))" OnClick="AnalyzeText" StartIcon="@Icons.Material.Outlined.AutoAwesome">
                                @(_aiBusy ? "AI analizuje opis…" : "Policz z opisu")
                            </MudButton>
                        }

                        @if (_aiDraft is not null)
                        {
                            <section class="ai-meal-draft">
                                <div class="ai-draft-heading">
                                    <div><span class="card-kicker">Propozycja AI</span><h3>Sprawdź przed zapisem</h3></div>
                                    <strong>@AiCalories.ToString("0") kcal</strong>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(_aiDraft.Note))
                                {
                                    <MudAlert Severity="Severity.Info" Dense="true">@_aiDraft.Note</MudAlert>
                                }
                                <MudTextField @bind-Value="_aiDraft.Name" Label="Nazwa dania" />
                                @foreach (var item in _aiDraft.Items)
                                {
                                    <div class="ai-food-item">
                                        <div class="ai-food-name">
                                            <MudTextField @bind-Value="item.Name" Label="Składnik" />
                                            <MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small" OnClick="() => _aiDraft.Items.Remove(item)" aria-label="Usuń składnik" />
                                        </div>
                                        <div class="ai-food-values">
                                            <MudNumericField @bind-Value="item.AmountGrams" Label="Ilość (g)" Min="1m" />
                                            <MudNumericField @bind-Value="item.CaloriesPer100" Label="kcal / 100 g" Min="0m" />
                                            <MudNumericField @bind-Value="item.ProteinPer100" Label="B / 100 g" Min="0m" />
                                            <MudNumericField @bind-Value="item.FatPer100" Label="T / 100 g" Min="0m" />
                                            <MudNumericField @bind-Value="item.CarbohydratesPer100" Label="W / 100 g" Min="0m" />
                                        </div>
                                    </div>
                                }
                                <MudButton Variant="Variant.Text" OnClick="AddAiItem" StartIcon="@Icons.Material.Outlined.Add">Dodaj składnik</MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Disabled="@(_savingAi || _aiDraft.Items.Count == 0)" OnClick="SaveAiMeal" Class="mt-2">
                                    @(_savingAi ? "Zapisuję…" : "Dodaj posiłek do dziennika")
                                </MudButton>
                                <MudText Typo="Typo.caption">Wartości rozpoznane przez AI są szacunkowe i możesz je poprawić.</MudText>
                            </section>
                        }
                    }
                </section>
            </MudTabPanel>
            <MudTabPanel Text="Produkty i cel">
                <section class="module-form fuel-form">
                    <div class="module-form-heading"><span class="card-kicker">Punkt odniesienia</span><h2>Dzienny cel</h2></div>
                    <div class="field-grid">
                        <MudNumericField @bind-Value="_target.Calories" Label="Kalorie (kcal)" Min="1m" />
                        <MudNumericField @bind-Value="_target.Protein" Label="Białko (g)" Min="0m" />
                        <MudNumericField @bind-Value="_target.Fat" Label="Tłuszcze (g)" Min="0m" />
                        <MudNumericField @bind-Value="_target.Carbs" Label="Węglowodany (g)" Min="0m" />
                    </div>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveTarget" Class="mt-3">Zapisz cel</MudButton>
                </section>

                <section class="module-form fuel-form">
                    <div class="module-form-heading"><span class="card-kicker">Baza produktów</span><h2>Dodaj produkt</h2><p>Wpisz wartości dla 100 g albo zacznij od kodu kreskowego.</p></div>
                    <div class="barcode-entry">
                        <MudTextField @bind-Value="_barcode" Label="Kod kreskowy" MaxLength="14" />
                        <MudIconButton Icon="@Icons.Material.Filled.Search" Color="Color.Primary" OnClick="LookupBarcode" aria-label="Wyszukaj kod" />
                    </div>
                    @if (_barcodeMessage is not null)
                    {
                        <MudAlert Severity="@(_barcodeUnavailable ? Severity.Warning : Severity.Info)" Dense="true" Class="mb-3">@_barcodeMessage</MudAlert>
                    }
                    <div class="field-grid">
                        <MudTextField @bind-Value="_product.Name" Label="Nazwa" />
                        <MudTextField @bind-Value="_product.Brand" Label="Marka (opcjonalnie)" />
                        <MudNumericField @bind-Value="_product.Calories" Label="Kalorie / 100 g" Min="0m" />
                        <MudNumericField @bind-Value="_product.Protein" Label="Białko / 100 g" Min="0m" />
                        <MudNumericField @bind-Value="_product.Fat" Label="Tłuszcze / 100 g" Min="0m" />
                        <MudNumericField @bind-Value="_product.Carbs" Label="Węglowodany / 100 g" Min="0m" />
                    </div>
                    <div class="set-entry">
                        <MudNumericField @bind-Value="_product.ServingAmount" Label="Porcja domyślna" Min="0.01m" />
                        <MudSelect T="ServingUnit" @bind-Value="_product.ServingUnit" Label="Jednostka porcji">
                            @foreach (var unit in Enum.GetValues<ServingUnit>()) { <MudSelectItem Value="@unit">@unit</MudSelectItem> }
                        </MudSelect>
                    </div>
                    @if (_product.ServingUnit == ServingUnit.Piece)
                    {
                        <MudNumericField @bind-Value="_product.GramsPerPiece" Label="Gramów na sztukę" Min="0.01m" />
                    }
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveProduct" Class="mt-3">Dodaj produkt</MudButton>
                </section>
            </MudTabPanel>
            }
    }
</MudContainer>

@code {
    private static bool ShowInlineMealEditor => false;
    [SupplyParameterFromQuery(Name = "date")] public string? DateQuery { get; set; }

    private static readonly System.Globalization.CultureInfo PolishCulture = new("pl-PL");
    private static DateOnly Today => DateOnly.FromDateTime(DateTime.Now);
    private DateOnly _date = Today;
    private readonly TargetForm _target = new();
    private readonly ProductForm _product = new();
    private readonly MealForm _meal = new();
    private IReadOnlyList<ProductResponse> _products = [];
    private IReadOnlyList<MealResponse> _recentMeals = [];
    private NutritionDayResponse? _day;
    private string _barcode = string.Empty;
    private string? _barcodeMessage;
    private bool _barcodeUnavailable;
    private bool _loading = true;
    private bool _dayLoading;
    private bool _aiBusy;
    private bool _savingAi;
    private string _mealDescription = string.Empty;
    private MealEntryMode _entryMode;
    private AiMealForm? _aiDraft;
    private Guid? _editingMealId;
    private string _productSearch = string.Empty;
    private decimal _basePortion = 100;
    private List<string> _mealSlots = ["Śniadanie", "Lunch", "Obiad", "Przekąska", "Kolacja"];
    private IReadOnlyList<MealScheduleEntry> _mealSchedule = [];
    private readonly HashSet<string> _openMealSlots = new(StringComparer.OrdinalIgnoreCase);
    private DayOfWeek _weekStartsOn = DayOfWeek.Monday;
    private string _selectedMealSlot = "Śniadanie";
    private decimal AiCalories => _aiDraft?.Items.Sum(x => x.AmountGrams * x.CaloriesPer100 / 100m) ?? 0;
    private string DayCaption => _date == Today ? "Dzisiaj" : _date == Today.AddDays(-1) ? "Wczoraj" : "Wybrany dzień";
    private int DayOffset(DateOnly date) => (7 + (int)date.DayOfWeek - (int)_weekStartsOn) % 7;
    private DateOnly WeekStart => _date.AddDays(-DayOffset(_date));
    private IEnumerable<DateOnly> WeekDays => Enumerable.Range(0, 7).Select(WeekStart.AddDays);
    private IEnumerable<ProductResponse> FilteredProducts => string.IsNullOrWhiteSpace(_productSearch)
        ? _products
        : _products.Where(x => x.Name.Contains(_productSearch, StringComparison.OrdinalIgnoreCase) || (x.Brand?.Contains(_productSearch, StringComparison.OrdinalIgnoreCase) ?? false));
    private string DayStatusTitle => _day?.Status switch
    {
        NutritionDayStatus.Complete => "Ten dzień jest zamknięty",
        NutritionDayStatus.Partial => "Dane są częściowe",
        NutritionDayStatus.NoData => "Dzień oznaczony jako brak danych",
        _ => "Niezdecydowano"
    };

    protected override async Task OnInitializedAsync()
    {
        if (DateOnly.TryParse(DateQuery, out var selected) && selected <= Today) _date = selected;
        if (await Account.GetCurrentUser() is null)
        {
            Navigation.NavigateTo("/");
            return;
        }

        var profile = await Account.GetProfile();
        _mealSlots = profile.MealSlots?.Where(x => !string.IsNullOrWhiteSpace(x)).ToList() ?? _mealSlots;
        _mealSchedule = profile.MealSchedule?.Where(x => x.Enabled).ToList() ?? [];
        _weekStartsOn = profile.WeekStartsOn;
        _selectedMealSlot = _mealSlots[0];
        await Reload();
        _loading = false;
    }

    private async Task Reload()
    {
        _day = await Nutrition.GetDay(_date);
        _products = await Nutrition.GetProducts();
        _recentMeals = await Nutrition.GetRecentMeals();
        if (_day.Target is not null)
        {
            _target.Calories = _day.Target.CaloriesKcal;
            _target.Protein = _day.Target.ProteinG;
            _target.Fat = _day.Target.FatG;
            _target.Carbs = _day.Target.CarbohydratesG;
        }
        foreach (var slot in _mealSlots.Where(slot => MealsFor(slot).Count > 0)) _openMealSlots.Add(slot);
    }

    private async Task ChangeDay(int offset)
    {
        var next = _date.AddDays(offset);
        if (next > Today) return;
        _date = next;
        CancelMealEdit();
        await LoadDay();
    }

    private async Task GoToday()
    {
        _date = Today;
        CancelMealEdit();
        await LoadDay();
    }

    private async Task SelectDay(DateOnly day)
    {
        if (day > Today || day == _date) return;
        _date = day;
        await LoadDay();
    }

    private async Task ChangeWeek(int offset)
    {
        var next = WeekStart.AddDays(offset * 7);
        if (next > Today) return;
        _date = next.AddDays(Math.Min(DayOffset(_date), Math.Max(0, Today.DayNumber - next.DayNumber)));
        await LoadDay();
    }

    private async Task LoadDay()
    {
        _dayLoading = true;
        try { await Reload(); }
        finally { _dayLoading = false; }
    }

    private void AddItem()
    {
        var product = _products.FirstOrDefault(x => x.Id == _meal.ProductId);
        if (product is null || _meal.AmountGrams <= 0) return;
        _meal.Items.Add(new MealDraftItem(product.Id, product.Name, _meal.AmountGrams));
        _meal.ProductId = null;
        _meal.AmountGrams = 100;
    }

    private void SelectProduct(Guid? id)
    {
        _meal.ProductId = id;
        var product = _products.FirstOrDefault(x => x.Id == id);
        _basePortion = product?.DefaultServingAmount ?? 100;
        if (product?.DefaultServingUnit == ServingUnit.Piece && product.GramsPerPiece is not null)
            _basePortion = product.GramsPerPiece.Value;
        _meal.AmountGrams = _basePortion;
    }

    private void ScalePortion(decimal multiplier) => _meal.AmountGrams = Math.Max(.01m, _basePortion * multiplier);

    private void SelectMode(MealEntryMode mode)
    {
        _entryMode = mode;
        _aiDraft = null;
    }

    private void StartMeal(string slot)
    {
        Navigation.NavigateTo($"/food/add?date={_date:yyyy-MM-dd}&slot={Uri.EscapeDataString(slot)}");
    }

    private void EditMeal(MealResponse meal, string slot)
    {
        Navigation.NavigateTo($"/food/add?date={_date:yyyy-MM-dd}&slot={Uri.EscapeDataString(slot)}&edit={meal.Id}");
    }

    private void CancelMealEdit()
    {
        _editingMealId = null;
        _meal.Name = string.Empty;
        _meal.Items.Clear();
    }

    private async Task CopyMeal(MealResponse meal)
    {
        var items = meal.Items.Where(x => x.ProductId is not null).Select(x => new MealItemRequest(x.ProductId!.Value, x.AmountGrams, x.IsEstimated)).ToList();
        if (items.Count == 0) { Snackbar.Add("Tego wpisu nie można skopiować automatycznie.", Severity.Info); return; }
        await Run(async () =>
        {
            await Nutrition.SaveMeal(new SaveMealRequest(meal.Name, EntryTime(), items));
            await Reload();
            Snackbar.Add("Posiłek skopiowany.", Severity.Success);
        });
    }

    private async Task CopyPreviousDay()
    {
        var previous = await Nutrition.GetDay(_date.AddDays(-1));
        var copied = 0;
        foreach (var meal in previous.Meals)
        {
            var items = meal.Items.Where(x => x.ProductId is not null).Select(x => new MealItemRequest(x.ProductId!.Value, x.AmountGrams, x.IsEstimated)).ToList();
            if (items.Count == 0) continue;
            await Nutrition.SaveMeal(new SaveMealRequest(meal.Name, EntryTime(), items));
            copied++;
        }
        await Reload();
        Snackbar.Add(copied == 0 ? "Poprzedniego dnia nie było posiłków do skopiowania." : $"Skopiowano {copied} posiłków.", copied == 0 ? Severity.Info : Severity.Success);
    }

    private async Task SetDayStatus(NutritionDayStatus status)
    {
        await Nutrition.SaveDayStatus(_date, status);
        await Reload();
        Snackbar.Add("Status dnia zapisany.", Severity.Success);
    }

    private Variant StatusVariant(NutritionDayStatus status) => _day?.Status == status ? Variant.Filled : Variant.Outlined;

    private async Task AnalyzePhoto(InputFileChangeEventArgs args)
    {
        if (args.File.Size > 12 * 1024 * 1024)
        {
            Snackbar.Add("Zdjęcie może mieć maksymalnie 12 MB.", Severity.Warning);
            return;
        }
        await Analyze(() => Nutrition.AnalyzeMealPhoto(args.File));
    }

    private async Task AnalyzeText() => await Analyze(() => Nutrition.AnalyzeMealText(_mealDescription));

    private async Task Analyze(Func<Task<MealPhotoDraftResponse>> action)
    {
        _aiBusy = true;
        try
        {
            var draft = await action();
            if (draft.Items.Count == 0)
            {
                Snackbar.Add("AI nie rozpoznało posiłku. Zrób wyraźniejsze zdjęcie albo doprecyzuj opis.", Severity.Info);
                return;
            }
            _aiDraft = new AiMealForm(draft.MealName, draft.Note, draft.Items.Select(x => new AiFoodForm(x)).ToList());
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            if (ex.Message.Contains("limit", StringComparison.OrdinalIgnoreCase))
            {
                _aiDraft = new AiMealForm("Przykładowy posiłek", "Model osiągnął limit. To szkic zastępczy. Wpisz własne składniki i popraw wartości przed zapisem.",
                [
                    new AiFoodForm { Name = "Pierś z kurczaka", AmountGrams = 150, CaloriesPer100 = 165, ProteinPer100 = 31, FatPer100 = 3.6m },
                    new AiFoodForm { Name = "Ryż gotowany", AmountGrams = 200, CaloriesPer100 = 130, ProteinPer100 = 2.7m, FatPer100 = .3m, CarbohydratesPer100 = 28 }
                ]);
            }
        }
        finally { _aiBusy = false; }
    }

    private void AddAiItem() => _aiDraft?.Items.Add(new AiFoodForm());

    private async Task SaveAiMeal()
    {
        if (_aiDraft is null) return;
        _savingAi = true;
        try
        {
            await Nutrition.SaveEstimatedMeal(new SaveEstimatedMealRequest(
                MealName(_aiDraft.Name),
                EntryTime(),
                _aiDraft.Items.Select(x => new SaveEstimatedMealItemRequest(x.Name, x.AmountGrams, x.CaloriesPer100, x.ProteinPer100, x.FatPer100, x.CarbohydratesPer100)).ToList()));
            _aiDraft = null;
            _mealDescription = string.Empty;
            await Reload();
            Snackbar.Add("Posiłek dodany do dziennika.", Severity.Success);
        }
        catch (HttpRequestException) { Snackbar.Add("Nie udało się zapisać posiłku.", Severity.Error); }
        finally { _savingAi = false; }
    }

    private async Task SaveMeal() => await Run(async () =>
    {
        var request = new SaveMealRequest(
            MealName(_meal.Name),
            EntryTime(),
            _meal.Items.Select(x => new MealItemRequest(x.ProductId, x.AmountGrams, false)).ToList(),
            _meal.DeductFromPantry);
        if (_editingMealId is Guid id) await Nutrition.UpdateMeal(id, request);
        else await Nutrition.SaveMeal(request);
        _editingMealId = null;
        _meal.Items.Clear();
        _meal.Name = string.Empty;
        await Reload();
        Snackbar.Add("Posiłek zapisany.", Severity.Success);
    });

    private async Task SaveTarget() => await Run(async () =>
    {
        await Nutrition.SaveTarget(new SaveNutritionTargetRequest(_date, _target.Calories, _target.Protein, _target.Fat, _target.Carbs));
        await Reload();
        Snackbar.Add("Cel zapisany.", Severity.Success);
    });

    private async Task SaveProduct() => await Run(async () =>
    {
        await Nutrition.SaveProduct(new SaveProductRequest(_product.Name, _product.Brand, _product.Calories, _product.Protein, _product.Fat, _product.Carbs, _product.ServingAmount, _product.ServingUnit, _product.GramsPerPiece, _product.Barcode));
        _product.Clear();
        await Reload();
        Snackbar.Add("Produkt dodany.", Severity.Success);
    });

    private async Task LookupBarcode()
    {
        if (_barcode.Length is < 8 or > 14 || _barcode.Any(x => !char.IsDigit(x)))
        {
            _barcodeMessage = "Kod musi zawierać od 8 do 14 cyfr.";
            return;
        }
        var result = await Nutrition.GetByBarcode(_barcode);
        _barcodeMessage = result.Message;
        _barcodeUnavailable = result.TemporarilyUnavailable;
        if (result.Product is null) return;
        var product = result.Product;
        _product.Name = product.Name; _product.Brand = product.Brand; _product.Calories = product.CaloriesPer100;
        _product.Protein = product.ProteinPer100; _product.Fat = product.FatPer100; _product.Carbs = product.CarbohydratesPer100;
        _product.ServingAmount = product.ServingAmount; _product.ServingUnit = product.ServingUnit; _product.Barcode = product.Barcode;
    }

    private async Task DeleteMeal(Guid id) => await Run(async () =>
    {
        await Nutrition.DeleteMeal(id);
        await Reload();
    });

    private List<MealResponse> MealsFor(string slot) => _day?.Meals.Where(x => BelongsTo(x.Name, slot)).ToList() ?? [];
    private List<MealResponse> UnassignedMeals => _day?.Meals.Where(x => !_mealSlots.Any(slot => BelongsTo(x.Name, slot))).ToList() ?? [];
    private MealScheduleEntry MealAppearance(string slot) =>
        _mealSchedule.FirstOrDefault(x => x.Name.Equals(slot, StringComparison.OrdinalIgnoreCase))
        ?? new MealScheduleEntry(slot, new TimeOnly(12, 0), true);
    private bool IsMealSlotOpen(string slot) => _openMealSlots.Contains(slot);
    private void ToggleMealSlot(string slot)
    {
        if (!_openMealSlots.Add(slot)) _openMealSlots.Remove(slot);
    }
    private static bool BelongsTo(string mealName, string slot) => mealName.Equals(slot, StringComparison.OrdinalIgnoreCase) || mealName.StartsWith(slot + " · ", StringComparison.OrdinalIgnoreCase);
    private static string DisplayMealName(string mealName, string slot) => mealName.StartsWith(slot + " · ", StringComparison.OrdinalIgnoreCase) ? mealName[(slot.Length + 3)..] : mealName;
    private string MealName(string? name) => string.IsNullOrWhiteSpace(name) ? _selectedMealSlot : $"{_selectedMealSlot} · {name.Trim()}";
    private DateTimeOffset EntryTime()
    {
        var local = _date.ToDateTime(TimeOnly.FromDateTime(DateTime.Now));
        return new DateTimeOffset(local, TimeZoneInfo.Local.GetUtcOffset(local));
    }

    private async Task Run(Func<Task> action)
    {
        try { await action(); }
        catch (HttpRequestException) { Snackbar.Add("Nie udało się zapisać zmian.", Severity.Error); }
    }

    private sealed class TargetForm
    {
        public decimal Calories { get; set; } = 2500;
        public decimal Protein { get; set; } = 160;
        public decimal Fat { get; set; } = 80;
        public decimal Carbs { get; set; } = 300;
    }

    private sealed class ProductForm
    {
        public string Name { get; set; } = string.Empty;
        public string? Brand { get; set; }
        public decimal Calories { get; set; }
        public decimal Protein { get; set; }
        public decimal Fat { get; set; }
        public decimal Carbs { get; set; }
        public decimal? ServingAmount { get; set; }
        public ServingUnit ServingUnit { get; set; }
        public decimal? GramsPerPiece { get; set; }
        public string? Barcode { get; set; }
        public void Clear()
        {
            (Name, Brand, Calories, Protein, Fat, Carbs) = (string.Empty, null, 0, 0, 0, 0);
            ServingAmount = GramsPerPiece = null; ServingUnit = ServingUnit.Gram; Barcode = null;
        }
    }

    private sealed class MealForm
    {
        public string Name { get; set; } = string.Empty;
        public Guid? ProductId { get; set; }
        public decimal AmountGrams { get; set; } = 100;
        public bool DeductFromPantry { get; set; }
        public List<MealDraftItem> Items { get; } = [];
    }

    private sealed record MealDraftItem(Guid ProductId, string Name, decimal AmountGrams);
    private enum MealEntryMode { Manual, Photo, Text }

    private sealed class AiMealForm(string name, string? note, List<AiFoodForm> items)
    {
        public string Name { get; set; } = name;
        public string? Note { get; } = note;
        public List<AiFoodForm> Items { get; } = items;
    }

    private sealed class AiFoodForm
    {
        public AiFoodForm() { }
        public AiFoodForm(MealPhotoItemDraft item) => (Name, AmountGrams, CaloriesPer100, ProteinPer100, FatPer100, CarbohydratesPer100) =
            (item.Name, item.AmountGrams, item.CaloriesPer100, item.ProteinPer100, item.FatPer100, item.CarbohydratesPer100);
        public string Name { get; set; } = string.Empty;
        public decimal AmountGrams { get; set; } = 100;
        public decimal CaloriesPer100 { get; set; }
        public decimal ProteinPer100 { get; set; }
        public decimal FatPer100 { get; set; }
        public decimal CarbohydratesPer100 { get; set; }
    }
}
