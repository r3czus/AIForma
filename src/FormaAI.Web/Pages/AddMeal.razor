@page "/food/add"
@inject AccountClient Account
@inject NutritionClient Nutrition
@inject PantryClient PantryApi
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>@(_editingMealId is null ? "Dodaj posiłek" : "Edytuj posiłek") · FormaAI</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="content-wrap meal-add-page">
    <header class="meal-add-header">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="ReturnToDiary" aria-label="Wróć do dziennika" />
        <div>
            <span class="page-kicker">@_date.ToString("dddd, d MMMM", PolishCulture)</span>
            <MudText Typo="Typo.h4">@(_editingMealId is null ? $"Dodaj: {_selectedMealSlot}" : $"Edytuj: {_selectedMealSlot}")</MudText>
        </div>
    </header>

    @if (_loading)
    {
        <div class="page-loader compact"><MudProgressCircular Indeterminate="true" Color="Color.Primary" /><span>Przygotowuję produkty</span></div>
    }
    else
    {
        <section class="meal-add-shell">
            <div class="meal-add-slot-row">
                <MudSelect T="string" @bind-Value="_selectedMealSlot" Label="Posiłek">
                    @foreach (var slot in _mealSlots) { <MudSelectItem Value="@slot">@slot</MudSelectItem> }
                </MudSelect>
                <span>@_date.ToString("dd.MM")</span>
            </div>

            <div class="meal-entry-modes meal-entry-modes-wide" role="group" aria-label="Sposób dodawania posiłku">
                <button type="button" class="@(_entryMode == MealEntryMode.Manual ? "selected" : null)" @onclick="() => SelectMode(MealEntryMode.Manual)"><MudIcon Icon="@Icons.Material.Outlined.Search" /><strong>Wyszukaj</strong><span>Produkty i porcje</span></button>
                <button type="button" class="@(_entryMode == MealEntryMode.Photo ? "selected" : null)" @onclick="() => SelectMode(MealEntryMode.Photo)"><MudIcon Icon="@Icons.Material.Outlined.PhotoCamera" /><strong>Zdjęcie AI</strong><span>Aparat lub galeria</span></button>
                <button type="button" class="@(_entryMode == MealEntryMode.Text ? "selected" : null)" @onclick="() => SelectMode(MealEntryMode.Text)"><MudIcon Icon="@Icons.Material.Outlined.AutoAwesome" /><strong>Opis AI</strong><span>Napisz, co zjadłeś</span></button>
            </div>

            @if (_entryMode == MealEntryMode.Manual)
            {
                <div class="meal-catalog-search">
                    <MudTextField T="string" Value="_productSearch" ValueChanged="@((string value) => SearchProducts(value))" Immediate="true" DebounceInterval="250" Placeholder="Szukaj produktu lub marki" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Outlined.Search" aria-label="Szukaj produktu" />
                </div>

                <nav class="meal-catalog-tabs" aria-label="Filtry produktów">
                    <button type="button" class="@(_catalogScope == CatalogScope.Search ? "active" : null)" @onclick="() => SetCatalogScope(CatalogScope.Search)">Szukaj</button>
                    <button type="button" class="@(_catalogScope == CatalogScope.Own ? "active" : null)" @onclick="() => SetCatalogScope(CatalogScope.Own)">Własne</button>
                    <button type="button" class="@(_catalogScope == CatalogScope.Favorites ? "active" : null)" @onclick="() => SetCatalogScope(CatalogScope.Favorites)">Ulubione</button>
                    <button type="button" class="@(_catalogScope == CatalogScope.Pantry ? "active" : null)" @onclick="() => SetCatalogScope(CatalogScope.Pantry)">Lodówka</button>
                </nav>

                <section class="meal-catalog" aria-live="polite">
                    @if (_catalogLoading)
                    {
                        <div class="meal-catalog-loading"><MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary" /><span>Szukam produktów…</span></div>
                    }
                    else if (_catalogScope == CatalogScope.Search && string.IsNullOrWhiteSpace(_productSearch))
                    {
                        <div class="meal-add-section-title"><span>Ostatnie w tej sekcji</span><small>Dodaj ponownie jednym dotknięciem</small></div>
                        @if (_recentMeals.Count > 0)
                        {
                            <div class="recent-meal-list">
                                @foreach (var recent in _recentMeals.Take(6))
                                {
                                    <button type="button" @onclick="() => CopyMeal(recent)"><span><strong>@RecentName(recent.Name)</strong><small>B @recent.Macro.ProteinG.ToString("0") g · T @recent.Macro.FatG.ToString("0") g · W @recent.Macro.CarbohydratesG.ToString("0") g</small></span><strong>@recent.Macro.CaloriesKcal.ToString("0") kcal</strong><MudIcon Icon="@Icons.Material.Outlined.ChevronRight" /></button>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="meal-catalog-empty">Zacznij pisać, aby znaleźć pierwszy produkt.</p>
                        }
                    }
                    else
                    {
                        @if (_catalogScope == CatalogScope.Own && _recentMeals.Count > 0)
                        {
                            <div class="meal-add-section-title"><span>Twoje gotowe dania</span><small>Zapisane wcześniej</small></div>
                            <div class="recent-meal-list compact-list">
                                @foreach (var recent in _recentMeals.Take(4))
                                {
                                    <button type="button" @onclick="() => CopyMeal(recent)"><span><strong>@RecentName(recent.Name)</strong><small>B @recent.Macro.ProteinG.ToString("0") g · T @recent.Macro.FatG.ToString("0") g · W @recent.Macro.CarbohydratesG.ToString("0") g</small></span><strong>@recent.Macro.CaloriesKcal.ToString("0") kcal</strong><MudIcon Icon="@Icons.Material.Outlined.ChevronRight" /></button>
                                }
                            </div>
                        }

                        @if (VisibleProducts.Count > 0)
                        {
                            <div class="meal-product-list">
                                @foreach (var product in VisibleProducts)
                                {
                                    var portion = DefaultPortion(product);
                                    <div class="meal-product-row @(IsSelected(product.Id) ? "selected" : null)">
                                        <input type="checkbox" checked="@IsSelected(product.Id)" @onchange="() => ToggleProduct(product)" aria-label="Dodaj @product.Name do posiłku" />
                                        <button type="button" class="meal-product-open" @onclick="() => OpenProduct(product)">
                                            <span><strong>@product.Name</strong><small>@(string.IsNullOrWhiteSpace(product.Brand) ? "Produkt" : product.Brand)</small></span>
                                            <span><strong>@PortionCalories(product, portion).ToString("0") kcal</strong><small>@portion.ToString("0.#") g</small></span>
                                            <MudIcon Icon="@Icons.Material.Outlined.ChevronRight" />
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="meal-catalog-empty">Brak produktów w tym widoku.</p>
                        }
                    }
                </section>

                <details class="meal-own-product">
                    <summary>Nie ma produktu? Dodaj własny</summary>
                    <div class="field-grid">
                        <MudTextField @bind-Value="_product.Name" Label="Nazwa produktu" />
                        <MudTextField @bind-Value="_product.Brand" Label="Marka (opcjonalnie)" />
                        <MudNumericField @bind-Value="_product.Calories" Label="Kalorie / 100 g" Min="0m" />
                        <MudNumericField @bind-Value="_product.Protein" Label="Białko / 100 g" Min="0m" />
                        <MudNumericField @bind-Value="_product.Fat" Label="Tłuszcze / 100 g" Min="0m" />
                        <MudNumericField @bind-Value="_product.Carbs" Label="Węglowodany / 100 g" Min="0m" />
                    </div>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Disabled="@(_savingProduct || string.IsNullOrWhiteSpace(_product.Name))" OnClick="SaveProduct" StartIcon="@Icons.Material.Outlined.Add">
                        @(_savingProduct ? "Dodaję…" : "Dodaj produkt do bazy")
                    </MudButton>
                </details>

                <MudTextField @bind-Value="_meal.Name" Label="Nazwa dania (opcjonalnie)" />
                @if (_meal.Items.Count > 0)
                {
                    <div class="meal-add-section-title"><span>Wybrane produkty</span><small>@_meal.Items.Count</small></div>
                    <div class="meal-draft-list">
                        @foreach (var item in _meal.Items)
                        {
                            <div><span><strong>@item.Name</strong><small>Ustaw ilość</small></span><MudNumericField @bind-Value="item.AmountGrams" Min="0.01m" Adornment="Adornment.End" AdornmentText="g" HideSpinButtons="true" aria-label="Ilość produktu" /><MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small" OnClick="() => _meal.Items.Remove(item)" aria-label="Usuń produkt" /></div>
                        }
                    </div>
                }
                <MudCheckBox @bind-Value="_meal.DeductFromPantry" Label="Odejmij składniki ze spiżarni" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large" Disabled="@(_saving || _meal.Items.Count == 0)" OnClick="SaveMeal" Class="meal-add-submit">
                    @(_saving ? "Zapisuję…" : _editingMealId is null ? "Dodaj posiłek" : "Zapisz zmiany")
                </MudButton>

                @if (_productDetails is not null)
                {
                    var product = _productDetails;
                    <div class="product-detail-backdrop" role="presentation">
                        <section class="product-detail-panel" role="dialog" aria-modal="true" aria-label="Szczegóły produktu @product.Name">
                            <header>
                                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="CloseProduct" aria-label="Wróć do listy produktów" />
                                <div><strong>@product.Name</strong><span>@(string.IsNullOrWhiteSpace(product.Brand) ? "Produkt własny" : product.Brand)</span></div>
                                <div class="product-detail-actions">
                                    @if (product.IsOwn) { <MudIconButton Icon="@Icons.Material.Outlined.Edit" OnClick="ToggleProductEditor" aria-label="Edytuj produkt" /> }
                                    <button type="button" class="product-detail-favorite @(IsFavorite(product.Id) ? "selected" : null)" @onclick="() => ToggleFavorite(product.Id)" aria-label="@(IsFavorite(product.Id) ? "Usuń z ulubionych" : "Dodaj do ulubionych")"><MudIcon Icon="@(IsFavorite(product.Id) ? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)" /></button>
                                </div>
                            </header>

                            @if (_editingProduct)
                            {
                                <section class="product-detail-editor">
                                    <div class="product-name-fields">
                                        <MudTextField @bind-Value="_productEdit.Name" Label="Nazwa produktu" />
                                        <MudTextField @bind-Value="_productEdit.Brand" Label="Marka (opcjonalnie)" />
                                    </div>
                                    <div class="product-macro-fields">
                                        <MudNumericField @bind-Value="_productEdit.Calories" Label="Kalorie / 100 g" Min="0m" HideSpinButtons="true" />
                                        <MudNumericField @bind-Value="_productEdit.Protein" Label="Białko / 100 g" Min="0m" HideSpinButtons="true" />
                                        <MudNumericField @bind-Value="_productEdit.Fat" Label="Tłuszcze / 100 g" Min="0m" HideSpinButtons="true" />
                                        <MudNumericField @bind-Value="_productEdit.Carbs" Label="Węglowodany / 100 g" Min="0m" HideSpinButtons="true" />
                                    </div>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Disabled="@(_savingProduct || string.IsNullOrWhiteSpace(_productEdit.Name))" OnClick="SaveProductChanges">@(_savingProduct ? "Zapisuję…" : "Zapisz dane produktu")</MudButton>
                                </section>
                            }

                            <div class="product-portion-list">
                                @foreach (var option in ProductPortions(product))
                                {
                                    <label class="@(IsPortionSelected(product.Id, option.AmountGrams) ? "selected" : null)">
                                        <input type="checkbox" checked="@IsPortionSelected(product.Id, option.AmountGrams)" @onchange="() => SelectPortion(product, option.AmountGrams)" />
                                        <span>@option.Name</span><strong>@option.AmountGrams.ToString("0.#") g</strong><span>@PortionCalories(product, option.AmountGrams).ToString("0") kcal</span>
                                    </label>
                                }
                            </div>

                            <div class="product-custom-portion">
                                <MudNumericField @bind-Value="_detailAmount" Min="1m" Label="Własna ilość" Adornment="Adornment.End" AdornmentText="g" HideSpinButtons="true" />
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => SelectPortion(product, _detailAmount)">Dodaj tę porcję</MudButton>
                            </div>

                            <div class="product-detail-energy"><span>Dla @_detailAmount.ToString("0.#") g</span><strong>@PortionCalories(product, _detailAmount).ToString("0") kcal</strong></div>
                            <div class="product-macro-rings">
                                <div style="@MacroProgressStyle(product.ProteinPer100, _detailAmount)"><i><strong>@MacroAmount(product.ProteinPer100, _detailAmount).ToString("0.#")</strong><small>g</small></i><span>Białko</span></div>
                                <div class="fat" style="@MacroProgressStyle(product.FatPer100, _detailAmount)"><i><strong>@MacroAmount(product.FatPer100, _detailAmount).ToString("0.#")</strong><small>g</small></i><span>Tłuszcze</span></div>
                                <div class="carbs" style="@MacroProgressStyle(product.CarbohydratesPer100, _detailAmount)"><i><strong>@MacroAmount(product.CarbohydratesPer100, _detailAmount).ToString("0.#")</strong><small>g</small></i><span>Węglowodany</span></div>
                            </div>
                            <MudButton Class="product-detail-done" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="() => ConfirmProduct(product)">Dodaj produkt</MudButton>
                        </section>
                    </div>
                }
            }
            else
            {
                @if (_entryMode == MealEntryMode.Photo)
                {
                    <label class="meal-photo-capture @(_aiBusy ? "busy" : null)">
                        <MudIcon Icon="@Icons.Material.Outlined.PhotoCamera" />
                        <strong>@(_aiBusy ? "AI analizuje zdjęcie…" : "Zrób zdjęcie posiłku")</strong>
                        <span>Na iPhonie otworzy się aparat. Możesz też wskazać zdjęcie z galerii.</span>
                        <InputFile OnChange="AnalyzePhoto" accept="image/jpeg,image/png,image/webp,image/heic,image/heif" capture="environment" disabled="@_aiBusy" />
                    </label>
                }
                else
                {
                    <MudTextField @bind-Value="_mealDescription" Immediate="true" Label="Co zjadłeś?" Lines="5" MaxLength="1000" Placeholder="Np. dwa jajka sadzone, dwie kromki chleba z masłem i pomidor" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large" Disabled="@(_aiBusy || string.IsNullOrWhiteSpace(_mealDescription))" OnClick="AnalyzeText" StartIcon="@Icons.Material.Outlined.AutoAwesome">
                        @(_aiBusy ? "AI analizuje opis…" : "Policz i przygotuj posiłek")
                    </MudButton>
                }

                @if (_aiBusy)
                {
                    <div class="ai-analysis-status" role="status" aria-live="polite">
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary" />
                        <div><strong>AI analizuje posiłek</strong><span>Rozpoznaję składniki i liczę wartości. Zwykle zajmuje to kilka sekund.</span></div>
                    </div>
                }

                @if (_aiDraft is not null)
                {
                    <section class="ai-meal-draft">
                        <div class="ai-draft-heading"><div><span class="card-kicker">Propozycja AI</span><h3>Sprawdź przed zapisem</h3></div><strong>@AiCalories.ToString("0") kcal</strong></div>
                        @if (!string.IsNullOrWhiteSpace(_aiDraft.Note)) { <MudAlert Severity="Severity.Info" Dense="true">@_aiDraft.Note</MudAlert> }
                        <MudTextField @bind-Value="_aiDraft.Name" Label="Nazwa dania" />
                        @foreach (var item in _aiDraft.Items)
                        {
                            <div class="ai-food-item">
                                <div class="ai-food-name"><MudTextField @bind-Value="item.Name" Label="Składnik" /><MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small" OnClick="() => _aiDraft.Items.Remove(item)" aria-label="Usuń składnik" /></div>
                                <div class="ai-food-values">
                                    <MudNumericField @bind-Value="item.AmountGrams" Label="Ilość (g)" Min="1m" />
                                    <MudNumericField @bind-Value="item.CaloriesPer100" Label="kcal / 100 g" Min="0m" />
                                    <MudNumericField @bind-Value="item.ProteinPer100" Label="B / 100 g" Min="0m" />
                                    <MudNumericField @bind-Value="item.FatPer100" Label="T / 100 g" Min="0m" />
                                    <MudNumericField @bind-Value="item.CarbohydratesPer100" Label="W / 100 g" Min="0m" />
                                </div>
                            </div>
                        }
                        <MudButton Variant="Variant.Text" OnClick="AddAiItem" StartIcon="@Icons.Material.Outlined.Add">Dodaj składnik</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large" Disabled="@(_saving || _aiDraft.Items.Count == 0)" OnClick="SaveAiMeal">@(_saving ? "Zapisuję…" : "Dodaj do dziennika")</MudButton>
                        <MudText Typo="Typo.caption">Wartości rozpoznane przez AI są szacunkowe i możesz je poprawić.</MudText>
                    </section>
                }
            }
        </section>
    }
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "date")] public string? DateQuery { get; set; }
    [SupplyParameterFromQuery(Name = "slot")] public string? SlotQuery { get; set; }
    [SupplyParameterFromQuery(Name = "edit")] public Guid? EditQuery { get; set; }

    private static readonly System.Globalization.CultureInfo PolishCulture = new("pl-PL");
    private const string FavoritesStorageKey = "formaai.favoriteProducts";
    private static DateOnly Today => DateOnly.FromDateTime(DateTime.Now);
    private DateOnly _date = Today;
    private IReadOnlyList<ProductResponse> _products = [];
    private IReadOnlyList<ProductResponse> _searchResults = [];
    private IReadOnlyList<MealResponse> _recentMeals = [];
    private IReadOnlyList<PantryItemResponse> _pantry = [];
    private HashSet<Guid> _favorites = [];
    private List<string> _mealSlots = ["Śniadanie", "Lunch", "Obiad", "Przekąska", "Kolacja"];
    private string _selectedMealSlot = "Śniadanie";
    private readonly MealForm _meal = new();
    private readonly ProductForm _product = new();
    private readonly ProductForm _productEdit = new();
    private string _productSearch = string.Empty;
    private ProductResponse? _productDetails;
    private decimal _detailAmount = 100;
    private MealEntryMode _entryMode;
    private CatalogScope _catalogScope;
    private string _mealDescription = string.Empty;
    private AiMealForm? _aiDraft;
    private bool _loading = true;
    private bool _aiBusy;
    private bool _saving;
    private bool _savingProduct;
    private bool _catalogLoading;
    private bool _editingProduct;
    private Guid? _editingMealId;
    private decimal AiCalories => _aiDraft?.Items.Sum(x => x.AmountGrams * x.CaloriesPer100 / 100m) ?? 0;
    private IReadOnlyList<ProductResponse> VisibleProducts => _catalogScope switch
    {
        CatalogScope.Search => _searchResults,
        CatalogScope.Own => _products.Where(x => x.IsOwn).ToList(),
        CatalogScope.Favorites => _products.Where(x => _favorites.Contains(x.Id)).ToList(),
        CatalogScope.Pantry => _products.Where(x => _pantry.Any(p => p.ProductId == x.Id)).ToList(),
        _ => []
    };

    protected override async Task OnInitializedAsync()
    {
        if (DateOnly.TryParse(DateQuery, out var selected) && selected <= Today) _date = selected;
        if (await Account.GetCurrentUser() is null) { Navigation.NavigateTo("/"); return; }

        var profile = await Account.GetProfile();
        _mealSlots = profile.MealSlots?.Where(x => !string.IsNullOrWhiteSpace(x)).ToList() ?? _mealSlots;
        _selectedMealSlot = _mealSlots.Contains(SlotQuery, StringComparer.OrdinalIgnoreCase) ? _mealSlots.First(x => x.Equals(SlotQuery, StringComparison.OrdinalIgnoreCase)) : _mealSlots[0];
        _products = await Nutrition.GetProducts();
        _recentMeals = await Nutrition.GetRecentMeals();
        _pantry = await PantryApi.GetPantry();
        var favoriteJson = await JS.InvokeAsync<string?>("localStorage.getItem", FavoritesStorageKey);
        if (!string.IsNullOrWhiteSpace(favoriteJson))
            _favorites = System.Text.Json.JsonSerializer.Deserialize<HashSet<Guid>>(favoriteJson) ?? [];

        if (EditQuery is Guid id)
        {
            var day = await Nutrition.GetDay(_date);
            var meal = day.Meals.FirstOrDefault(x => x.Id == id);
            if (meal is not null)
            {
                _editingMealId = id;
                _meal.Name = DisplayMealName(meal.Name);
                _meal.Items.AddRange(meal.Items.Where(x => x.ProductId is not null).Select(x => new MealDraftItem(x.ProductId!.Value, x.ProductName, x.AmountGrams)));
            }
        }
        _loading = false;
    }

    private void ReturnToDiary() => Navigation.NavigateTo($"/food?date={_date:yyyy-MM-dd}");
    private void SelectMode(MealEntryMode mode) { _entryMode = mode; _aiDraft = null; }
    private void SetCatalogScope(CatalogScope scope) => _catalogScope = scope;

    private async Task SearchProducts(string value)
    {
        _productSearch = value;
        _catalogScope = CatalogScope.Search;
        if (string.IsNullOrWhiteSpace(value)) { _searchResults = []; return; }
        _catalogLoading = true;
        try { _searchResults = await Nutrition.GetProducts(value.Trim()); }
        finally { _catalogLoading = false; }
    }

    private void ToggleProduct(ProductResponse product)
    {
        var selected = _meal.Items.FirstOrDefault(x => x.ProductId == product.Id);
        if (selected is not null) _meal.Items.Remove(selected);
        else _meal.Items.Add(new MealDraftItem(product.Id, product.Name, DefaultPortion(product)));
    }

    private void OpenProduct(ProductResponse product)
    {
        _productDetails = product;
        _detailAmount = _meal.Items.FirstOrDefault(x => x.ProductId == product.Id)?.AmountGrams ?? DefaultPortion(product);
        _productEdit.Load(product);
        _editingProduct = false;
    }

    private void CloseProduct() { _productDetails = null; _editingProduct = false; }
    private void ToggleProductEditor() => _editingProduct = !_editingProduct;

    private async Task SaveProductChanges()
    {
        if (_productDetails is null || string.IsNullOrWhiteSpace(_productEdit.Name)) return;
        _savingProduct = true;
        try
        {
            var saved = await Nutrition.UpdateProduct(_productDetails.Id, _productEdit.Request());
            _products = ReplaceProduct(_products, saved);
            _searchResults = ReplaceProduct(_searchResults, saved);
            var selected = _meal.Items.FirstOrDefault(x => x.ProductId == saved.Id);
            if (selected is not null) selected.Name = saved.Name;
            _productDetails = saved;
            _editingProduct = false;
            Snackbar.Add("Dane produktu zostały poprawione.", Severity.Success);
        }
        catch (HttpRequestException)
        {
            Snackbar.Add("Nie udało się zapisać zmian produktu.", Severity.Error);
        }
        finally { _savingProduct = false; }
    }

    private static IReadOnlyList<ProductResponse> ReplaceProduct(IReadOnlyList<ProductResponse> items, ProductResponse saved) =>
        items.Select(x => x.Id == saved.Id ? saved : x).ToList();

    private void ConfirmProduct(ProductResponse product)
    {
        SelectPortion(product, _detailAmount);
        CloseProduct();
    }

    private void SelectPortion(ProductResponse product, decimal amount)
    {
        _detailAmount = amount;
        var selected = _meal.Items.FirstOrDefault(x => x.ProductId == product.Id);
        if (selected is null) _meal.Items.Add(new MealDraftItem(product.Id, product.Name, amount));
        else selected.AmountGrams = amount;
    }

    private bool IsPortionSelected(Guid id, decimal amount) => _meal.Items.Any(x => x.ProductId == id && x.AmountGrams == amount);
    private static decimal MacroAmount(decimal per100, decimal amount) => per100 * amount / 100m;
    private static decimal MacroProgress(decimal per100, decimal amount) => Math.Min(100, MacroAmount(per100, amount) * 2);
    private static string MacroProgressStyle(decimal per100, decimal amount) =>
        $"--macro-progress: {MacroProgress(per100, amount).ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)}%";

    private static IReadOnlyList<ProductPortion> ProductPortions(ProductResponse product)
    {
        var portions = new List<ProductPortion> { new(DefaultPortion(product), product.DefaultServingUnit == ServingUnit.Piece ? "1 sztuka" : "Domyślna porcja") };
        foreach (var amount in new[] { 50m, 100m, 200m })
            if (portions.All(x => x.AmountGrams != amount)) portions.Add(new ProductPortion(amount, $"{amount:0} g"));
        return portions;
    }

    private bool IsSelected(Guid id) => _meal.Items.Any(x => x.ProductId == id);
    private bool IsFavorite(Guid id) => _favorites.Contains(id);
    private static decimal DefaultPortion(ProductResponse product) => product.DefaultServingUnit == ServingUnit.Piece && product.GramsPerPiece is not null
        ? product.GramsPerPiece.Value
        : product.DefaultServingAmount ?? 100;
    private static decimal PortionCalories(ProductResponse product, decimal portion) => product.CaloriesPer100 * portion / 100m;

    private async Task ToggleFavorite(Guid id)
    {
        if (!_favorites.Add(id)) _favorites.Remove(id);
        await JS.InvokeVoidAsync("localStorage.setItem", FavoritesStorageKey, System.Text.Json.JsonSerializer.Serialize(_favorites));
    }

    private async Task SaveProduct()
    {
        if (string.IsNullOrWhiteSpace(_product.Name)) return;
        _savingProduct = true;
        try
        {
            var saved = await Nutrition.SaveProduct(new SaveProductRequest(_product.Name.Trim(), _product.Brand, _product.Calories, _product.Protein, _product.Fat, _product.Carbs, 100, ServingUnit.Gram));
            _products = _products.Append(saved).OrderBy(x => x.Name).ToList();
            _searchResults = _searchResults.Append(saved).ToList();
            ToggleProduct(saved);
            _product.Clear();
            Snackbar.Add("Produkt dodany. Ustaw porcję i dodaj go do posiłku.", Severity.Success);
        }
        catch (HttpRequestException)
        {
            Snackbar.Add("Nie udało się dodać produktu.", Severity.Error);
        }
        finally { _savingProduct = false; }
    }

    private async Task CopyMeal(MealResponse meal) => await Save(async () =>
    {
        var items = meal.Items.Where(x => x.ProductId is not null).Select(x => new MealItemRequest(x.ProductId!.Value, x.AmountGrams, x.IsEstimated)).ToList();
        if (items.Count == 0) return;
        await Nutrition.SaveMeal(new SaveMealRequest(MealName(RecentName(meal.Name)), EntryTime(), items));
    });

    private async Task SaveMeal() => await Save(async () =>
    {
        var request = new SaveMealRequest(MealName(_meal.Name), EntryTime(), _meal.Items.Select(x => new MealItemRequest(x.ProductId, x.AmountGrams, false)).ToList(), _meal.DeductFromPantry);
        if (_editingMealId is Guid id) await Nutrition.UpdateMeal(id, request); else await Nutrition.SaveMeal(request);
    });

    private async Task AnalyzePhoto(InputFileChangeEventArgs args)
    {
        if (args.File.Size > 12 * 1024 * 1024) { Snackbar.Add("Zdjęcie może mieć maksymalnie 12 MB.", Severity.Warning); return; }
        await Analyze(() => Nutrition.AnalyzeMealPhoto(args.File));
    }
    private async Task AnalyzeText() => await Analyze(() => Nutrition.AnalyzeMealText(_mealDescription));
    private async Task Analyze(Func<Task<MealPhotoDraftResponse>> action)
    {
        _aiBusy = true;
        try
        {
            var draft = await action();
            if (draft.Items.Count == 0) { Snackbar.Add("AI nie rozpoznało posiłku. Spróbuj ponownie z wyraźniejszym zdjęciem lub opisem.", Severity.Info); return; }
            _aiDraft = new AiMealForm(draft.MealName, draft.Note, draft.Items.Select(x => new AiFoodForm(x)).ToList());
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            if (ex.Message.Contains("limit", StringComparison.OrdinalIgnoreCase))
                _aiDraft = new AiMealForm("Przykładowy posiłek", "Model osiągnął limit. Popraw szkic przed zapisem.", [new AiFoodForm { Name = "Pierś z kurczaka", AmountGrams = 150, CaloriesPer100 = 165, ProteinPer100 = 31, FatPer100 = 3.6m }, new AiFoodForm { Name = "Ryż gotowany", AmountGrams = 200, CaloriesPer100 = 130, ProteinPer100 = 2.7m, FatPer100 = .3m, CarbohydratesPer100 = 28 }]);
        }
        finally { _aiBusy = false; }
    }
    private void AddAiItem() => _aiDraft?.Items.Add(new AiFoodForm());
    private async Task SaveAiMeal()
    {
        if (_aiDraft is null) return;
        await Save(() => Nutrition.SaveEstimatedMeal(new SaveEstimatedMealRequest(MealName(_aiDraft.Name), EntryTime(), _aiDraft.Items.Select(x => new SaveEstimatedMealItemRequest(x.Name, x.AmountGrams, x.CaloriesPer100, x.ProteinPer100, x.FatPer100, x.CarbohydratesPer100)).ToList())));
    }
    private async Task Save(Func<Task> action)
    {
        _saving = true;
        try { await action(); Snackbar.Add("Posiłek zapisany.", Severity.Success); ReturnToDiary(); }
        catch (HttpRequestException) { Snackbar.Add("Nie udało się zapisać posiłku.", Severity.Error); }
        finally { _saving = false; }
    }

    private string MealName(string? name) => string.IsNullOrWhiteSpace(name) ? _selectedMealSlot : $"{_selectedMealSlot} · {name.Trim()}";
    private string DisplayMealName(string name) => name.StartsWith(_selectedMealSlot + " · ", StringComparison.OrdinalIgnoreCase) ? name[(_selectedMealSlot.Length + 3)..] : name;
    private string RecentName(string name)
    {
        var slot = _mealSlots.FirstOrDefault(x => name.StartsWith(x + " · ", StringComparison.OrdinalIgnoreCase));
        return slot is null ? name : name[(slot.Length + 3)..];
    }
    private DateTimeOffset EntryTime()
    {
        var local = _date.ToDateTime(TimeOnly.FromDateTime(DateTime.Now));
        return new DateTimeOffset(local, TimeZoneInfo.Local.GetUtcOffset(local));
    }

    private sealed class MealForm
    {
        public string Name { get; set; } = string.Empty;
        public bool DeductFromPantry { get; set; }
        public List<MealDraftItem> Items { get; } = [];
    }

    private sealed class ProductForm
    {
        public string Name { get; set; } = string.Empty;
        public string? Brand { get; set; }
        public decimal Calories { get; set; }
        public decimal Protein { get; set; }
        public decimal Fat { get; set; }
        public decimal Carbs { get; set; }

        public SaveProductRequest Request() => new(Name.Trim(), Brand, Calories, Protein, Fat, Carbs, 100, ServingUnit.Gram);

        public void Load(ProductResponse product)
        {
            Name = product.Name;
            Brand = product.Brand;
            Calories = product.CaloriesPer100;
            Protein = product.ProteinPer100;
            Fat = product.FatPer100;
            Carbs = product.CarbohydratesPer100;
        }

        public void Clear()
        {
            Name = string.Empty;
            Brand = null;
            Calories = Protein = Fat = Carbs = 0;
        }
    }
    private sealed class MealDraftItem(Guid productId, string name, decimal amountGrams)
    {
        public Guid ProductId { get; } = productId;
        public string Name { get; set; } = name;
        public decimal AmountGrams { get; set; } = amountGrams;
    }
    private sealed record ProductPortion(decimal AmountGrams, string Name);
    private enum MealEntryMode { Manual, Photo, Text }
    private enum CatalogScope { Search, Own, Favorites, Pantry }
    private sealed class AiMealForm(string name, string? note, List<AiFoodForm> items) { public string Name { get; set; } = name; public string? Note { get; } = note; public List<AiFoodForm> Items { get; } = items; }
    private sealed class AiFoodForm
    {
        public AiFoodForm() { }
        public AiFoodForm(MealPhotoItemDraft item) => (Name, AmountGrams, CaloriesPer100, ProteinPer100, FatPer100, CarbohydratesPer100) = (item.Name, item.AmountGrams, item.CaloriesPer100, item.ProteinPer100, item.FatPer100, item.CarbohydratesPer100);
        public string Name { get; set; } = string.Empty;
        public decimal AmountGrams { get; set; } = 100;
        public decimal CaloriesPer100 { get; set; }
        public decimal ProteinPer100 { get; set; }
        public decimal FatPer100 { get; set; }
        public decimal CarbohydratesPer100 { get; set; }
    }
}
