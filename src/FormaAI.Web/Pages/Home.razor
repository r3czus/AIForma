@page "/"
@inject AccountClient Account
@inject NutritionClient Nutrition
@inject TrainingClient TrainingApi
@inject ProgressClient ProgressApi
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>FormaAI</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="content-wrap home-page">
    @if (_loading)
    {
        <PageSkeleton Message="Synchronizuję plan dnia" />
    }
    else if (_user is null)
    {
        <section class="auth-shell">
            <div class="auth-intro">
                <span class="page-kicker">Ruch · paliwo · rytm</span>
                <h1>Forma nie dzieje się kiedyś. <em>Zaczyna się dzisiaj.</em></h1>
                <p>Połącz trening, jedzenie i progres w jednym spokojnym rytmie. FormaAI podpowiada kolejny krok, a decyzja zawsze zostaje po Twojej stronie.</p>
                <div class="performance-tape" aria-label="Obszary aplikacji">
                    <span>Trening</span><i></i><span>Odżywianie</span><i></i><span>Progres</span>
                </div>
            </div>

            <MudPaper Class="auth-card" Elevation="0">
                <span class="card-kicker">Twoja przestrzeń</span>
                <h2>Wejdź do planu dnia</h2>
                <p class="auth-copy">Zaloguj się albo utwórz konto w mniej niż minutę.</p>
                <MudTabs @bind-ActivePanelIndex="_tab">
                    <MudTabPanel Text="Logowanie">
                        <EditForm Model="_login">
                            <MudTextField @bind-Value="_login.Email" Label="E-mail" InputType="InputType.Email" Immediate="true" Required="true" />
                            <MudTextField @bind-Value="_login.Password" Label="Hasło" InputType="InputType.Password" Immediate="true" Required="true" />
                            <MudButton OnClick="Login" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-4">Przejdź do pulpitu</MudButton>
                        </EditForm>
                    </MudTabPanel>
                    <MudTabPanel Text="Nowe konto">
                        <EditForm Model="_register">
                            <MudTextField @bind-Value="_register.Email" Label="E-mail" InputType="InputType.Email" Immediate="true" Required="true" />
                            <MudTextField @bind-Value="_register.Password" Label="Hasło" InputType="InputType.Password" Immediate="true" Required="true" />
                            <MudTextField @bind-Value="_register.TimeZoneId" Label="Strefa czasowa" Immediate="true" Required="true" HelperText="Np. Europe/Warsaw" />
                            <MudButton OnClick="Register" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-4">Utwórz konto</MudButton>
                        </EditForm>
                    </MudTabPanel>
                </MudTabs>
            </MudPaper>
        </section>
    }
    else
    {
        <header class="dashboard-hero">
            <div>
                <span class="page-kicker">@DateTime.Now.ToString("dddd · d MMMM")</span>
                <h1>Twój plan na dziś</h1>
                <p>Najpierw kolejny dobry krok. Reszta może poczekać.</p>
            </div>
            <MudButton Href="/assistant" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.AutoAwesome">Zapytaj asystenta</MudButton>
        </header>

        <section class="quick-capture" aria-label="Szybkie dodawanie">
            <div class="quick-capture-intro">
                <span class="card-kicker">Zapisz działanie</span>
                <strong>Co chcesz zrobić?</strong>
                <small>Ręcznie albo z pomocą AI. Ty zatwierdzasz wynik.</small>
            </div>
            <div class="quick-capture-group">
                <span>Jedzenie</span>
                <MudButton Href="/food/add" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Outlined.Add">Dodaj posiłek</MudButton>
                <MudButton Href="/food/add?mode=text" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.AutoAwesome">Opisz przez AI</MudButton>
            </div>
            <div class="quick-capture-group">
                <span>Trening</span>
                <MudButton Href="/training?new=plan" Variant="Variant.Outlined" StartIcon="@Icons.Material.Outlined.Add">Utwórz plan</MudButton>
                <MudButton Href="/assistant?prompt=Chcę utworzyć nowy plan treningowy. Przeprowadź mnie przez krótką rozmowę, przygotuj kompletny plan do sprawdzenia i zapisz go dopiero po moim zatwierdzeniu." Variant="Variant.Text" StartIcon="@Icons.Material.Filled.AutoAwesome">Ułóż z AI</MudButton>
            </div>
        </section>

        <MudPaper Class="daily-coach" Elevation="0" aria-label="Sygnał dnia" Style="@($"--signal-progress: {WeekProgress}%")">
            <span class="card-kicker">Sygnał dnia · kolejny krok</span>
            <div class="daily-coach-content">
                <div>
                    <h2>@CoachTitle</h2>
                    <p>@CoachDescription</p>
                </div>
                <MudButton Href="@CoachUrl" Variant="Variant.Filled" Color="Color.Primary">@CoachAction</MudButton>
            </div>
            <div class="momentum-strip">
                <strong>@WeekWorkouts / @WeekGoal treningów w tym tygodniu</strong>
                <span>@MomentumCopy</span>
            </div>
        </MudPaper>

        <div class="dashboard-grid">
            <main class="dashboard-main">
                @if (_todayWorkout is not null)
                {
                    <MudPaper Class="workout-today" Elevation="0">
                        <div class="card-heading">
                            <div>
                                <span class="card-kicker">Dzisiejszy trening · @_todayWorkout.PlanName</span>
                                <h2>@_todayWorkout.DayName</h2>
                            </div>
                            <span class="data-chip">około @EstimateMinutes(_todayWorkout) min</span>
                        </div>
                        <div class="workout-preview">
                            @foreach (var exercise in _todayWorkout.Exercises.Take(4))
                            {
                                <div>
                                    <span>@exercise.ExerciseName</span>
                                    <strong>@exercise.Sets × @exercise.MinReps-@exercise.MaxReps</strong>
                                </div>
                            }
                        </div>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.PlayArrow" Disabled="_todayWorkout.AlreadyCompleted" OnClick="StartWorkout" Class="workout-start">
                            @(_todayWorkout.AlreadyCompleted ? "Trening wykonany" : "Rozpocznij trening")
                        </MudButton>
                        @if (_plans.SelectMany(x => x.Days).Any())
                        {
                            <div class="workout-choice-row">
                                <MudSelect T="Guid?" @bind-Value="_selectedTrainingDay" Label="Wybierz inny trening" Variant="Variant.Outlined" Dense="true">
                                    @foreach (var plan in _plans)
                                    {
                                        @foreach (var day in plan.Days)
                                        {
                                            <MudSelectItem T="Guid?" Value="day.Id">@plan.Name · @day.Name</MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Disabled="_selectedTrainingDay is null" OnClick="StartSelectedWorkout">
                                    Rozpocznij wybrany
                                </MudButton>
                            </div>
                        }
                        <MudButton Href="/assistant?prompt=Chcę wygenerować nowy trening. Zapytaj mnie o potrzebne szczegóły, przygotuj propozycję do sprawdzenia i zapisz ją dopiero po moim zatwierdzeniu." Variant="Variant.Text" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.AutoAwesome" Class="workout-ai-link">
                            Wygeneruj trening z AI
                        </MudButton>
                    </MudPaper>
                }
                else
                {
                    <MudPaper Class="workout-today workout-empty" Elevation="0">
                        <span class="card-kicker">Dzisiejszy trening</span>
                        <h2>Dzień bez przypisanego planu</h2>
                        <p>Regeneruj się albo zaplanuj sesję, jeśli chcesz dziś trenować.</p>
                        <MudButton Href="/training" Variant="Variant.Outlined">Przejdź do planów</MudButton>
                    </MudPaper>
                }

                @if (_day is not null)
                {
                    <MacroSummary Day="_day" />
                    <section class="meal-log">
                        <div class="section-heading">
                            <div><span class="card-kicker">Dziennik</span><h2>Dzisiejsze posiłki</h2></div>
                            <MudButton Href="/food/add" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Add">Dodaj posiłek</MudButton>
                        </div>
                        @foreach (var slot in _mealSlots)
                        {
                            var meals = MealsFor(slot);
                            var calories = meals.Sum(x => x.Macro.CaloriesKcal);
                            var protein = meals.Sum(x => x.Macro.ProteinG);
                            var carbohydrates = meals.Sum(x => x.Macro.CarbohydratesG);
                            var fat = meals.Sum(x => x.Macro.FatG);
                            var appearance = MealAppearance(slot);
                            <section class="meal-slot meal-theme-@appearance.Color @(IsMealSlotOpen(slot) ? "open" : null)">
                                <header class="meal-slot-heading">
                                    <button type="button" class="meal-slot-toggle" @onclick="() => ToggleMealSlot(slot)" disabled="@(meals.Count == 0)" aria-expanded="@IsMealSlotOpen(slot)">
                                        <MealSlotIcon IconKey="@appearance.Icon" ColorKey="@appearance.Color" />
                                        <span class="meal-slot-copy">
                                            <strong>@slot</strong>
                                            <small>@(meals.Count == 0 ? "Nie dodano produktów" : $"{meals.Count} pozycji")</small>
                                        </span>
                                    </button>
                                    <div class="meal-slot-stats" aria-label="Podsumowanie posiłku">
                                        @if (meals.Count > 0)
                                        {
                                            <span class="calories">@calories.ToString("0") kcal</span>
                                            <span>B @protein.ToString("0.#") g</span>
                                            <span>W @carbohydrates.ToString("0.#") g</span>
                                            <span>T @fat.ToString("0.#") g</span>
                                        }
                                        else
                                        {
                                            <time>@appearance.Time.ToString("HH:mm")</time>
                                        }
                                    </div>
                                    @if (meals.Count == 0)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Outlined.Add" Href="@MealEntryUrl(slot)" aria-label="@($"Dodaj do sekcji {slot}")" />
                                    }
                                    else
                                    {
                                        <MudIconButton Icon="@(IsMealSlotOpen(slot) ? Icons.Material.Filled.KeyboardArrowUp : Icons.Material.Filled.KeyboardArrowDown)" OnClick="() => ToggleMealSlot(slot)" aria-label="@($"Pokaż lub ukryj sekcję {slot}")" />
                                    }
                                </header>
                                @if (meals.Count > 0 && IsMealSlotOpen(slot))
                                {
                                    @foreach (var meal in meals)
                                    {
                                        <MudPaper Class="meal-row" Elevation="0">
                                            <div class="row-copy">
                                                <MudText Typo="Typo.subtitle1">@DisplayMealName(meal.Name, slot)</MudText>
                                                <MudText Typo="Typo.caption">@string.Join(" · ", meal.Items.Select(x => x.ProductName))</MudText>
                                            </div>
                                            <div class="meal-actions">
                                                <MudText Class="data-value">@meal.Macro.CaloriesKcal.ToString("0") kcal</MudText>
                                                <MudIconButton Icon="@Icons.Material.Outlined.Edit" Size="Size.Small" Href="@MealEditUrl(meal.Id, slot)" aria-label="Edytuj pozycję" />
                                                <MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteMeal(meal.Id)" aria-label="Usuń pozycję" />
                                            </div>
                                        </MudPaper>
                                    }
                                    <MudButton Href="@MealEntryUrl(slot)" Variant="Variant.Text" StartIcon="@Icons.Material.Outlined.Add" Class="meal-slot-add">Dodaj produkt</MudButton>
                                }
                            </section>
                        }
                        @if (UnassignedMeals.Count > 0)
                        {
                            <section class="meal-slot meal-slot-unassigned">
                                <header class="meal-slot-heading">
                                    <div>
                                        <strong>Pozostałe wpisy</strong>
                                        <span>@UnassignedMeals.Count pozycji · @UnassignedMeals.Sum(x => x.Macro.CaloriesKcal).ToString("0") kcal</span>
                                        <span class="meal-slot-macros">Wpisy zapisane bez przypisanej sekcji posiłku</span>
                                    </div>
                                </header>
                                @foreach (var meal in UnassignedMeals)
                                {
                                    <MudPaper Class="meal-row" Elevation="0">
                                        <div class="row-copy">
                                            <MudText Typo="Typo.subtitle1">@meal.Name</MudText>
                                            <MudText Typo="Typo.caption">@string.Join(" · ", meal.Items.Select(x => x.ProductName))</MudText>
                                        </div>
                                        <div class="meal-actions">
                                            <MudText Class="data-value">@meal.Macro.CaloriesKcal.ToString("0") kcal</MudText>
                                            <MudIconButton Icon="@Icons.Material.Outlined.Edit" Size="Size.Small" Href="@MealEditUrl(meal.Id, null)" aria-label="Edytuj pozycję" />
                                            <MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteMeal(meal.Id)" aria-label="Usuń pozycję" />
                                        </div>
                                    </MudPaper>
                                }
                            </section>
                        }
                    </section>
                }
            </main>

        </div>
    }
</MudContainer>

@code {
    private readonly LoginForm _login = new();
    private readonly RegisterForm _register = new();
    private CurrentUserResponse? _user;
    private UserProfileResponse? _profile;
    private NutritionDayResponse? _day;
    private List<string> _mealSlots = ["Śniadanie", "Lunch", "Obiad", "Przekąska", "Kolacja"];
    private IReadOnlyList<MealScheduleEntry> _mealSchedule = [];
    private readonly HashSet<string> _openMealSlots = new(StringComparer.OrdinalIgnoreCase);
    private TodayWorkoutResponse? _todayWorkout;
    private IReadOnlyList<TrainingPlanResponse> _plans = [];
    private WorkoutSessionResponse? _activeSession;
    private ConsistencyResponse? _consistency;
    private Guid? _selectedTrainingDay;
    private bool _loading = true;
    private int _tab;
    private static int EstimateMinutes(TodayWorkoutResponse workout) => Math.Max(20,
        (int)Math.Ceiling(workout.Exercises.Sum(x => x.Sets * ((x.RestSeconds ?? 90) + 45)) / 60d));
    private int WeekGoal => _profile?.PlannedTrainingsPerWeek ?? 0;
    private int WeekWorkouts => _consistency?.CompletedWorkouts ?? 0;
    private int WeekProgress => WeekGoal <= 0 ? 0 : Math.Clamp((int)Math.Round(WeekWorkouts * 100d / WeekGoal), 0, 100);
    private string MomentumCopy => WeekGoal == 0 ? "Ustaw tygodniowy cel w profilu" : WeekWorkouts >= WeekGoal ? "Cel tygodniowy wykonany" : "Każda ukończona sesja buduje rytm";
    private string CoachTitle => _activeSession is not null ? "Wróć do rozpoczętego treningu"
        : _todayWorkout is { AlreadyCompleted: false } ? $"Dzisiaj wypada {_todayWorkout.DayName}"
        : _day?.Status == NutritionDayStatus.Unknown && DateTime.Now.Hour >= 19 ? "Domknij dzisiejszy dziennik"
        : _day?.Target is not null && _day.Remaining?.ProteinG > 20 ? $"Zostało około {_day.Remaining.ProteinG:0} g białka"
        : "Dzisiejszy plan jest pod kontrolą";
    private string CoachDescription => _activeSession is not null ? "Sesja czeka dokładnie w miejscu, w którym ją przerwałeś."
        : _todayWorkout is { AlreadyCompleted: false } ? $"Plan ma {_todayWorkout.Exercises.Count} ćwiczeń i zajmie około {EstimateMinutes(_todayWorkout)} minut."
        : _day?.Status == NutritionDayStatus.Unknown && DateTime.Now.Hour >= 19 ? "Potwierdź kompletność albo oznacz dane jako częściowe. Podsumowanie tygodnia będzie dzięki temu wiarygodne."
        : _day?.Target is not null && _day.Remaining?.ProteinG > 20 ? "Cel nadal jest możliwy do osiągnięcia. Dodaj posiłek albo poproś AI o propozycję."
        : "Nie musisz dodawać kolejnego obowiązku. Utrzymaj spokojny rytm.";
    private string CoachAction => _activeSession is not null ? "Wróć do treningu"
        : _todayWorkout is { AlreadyCompleted: false } ? "Rozpocznij trening"
        : _day?.Status == NutritionDayStatus.Unknown && DateTime.Now.Hour >= 19 ? "Otwórz dziennik"
        : _day?.Target is not null && _day.Remaining?.ProteinG > 20 ? "Zaproponuj posiłek"
        : "Zobacz progres";
    private string CoachUrl => _activeSession is not null ? $"/workout/{_activeSession.Id}"
        : _todayWorkout is { AlreadyCompleted: false } ? "/training"
        : _day?.Status == NutritionDayStatus.Unknown && DateTime.Now.Hour >= 19 ? "/food"
        : _day?.Target is not null && _day.Remaining?.ProteinG > 20 ? MealSuggestionUrl
        : "/progress";
    private string MealSuggestionUrl
    {
        get
        {
            var remaining = _day?.Remaining;
            var prompt = $"Zaproponuj mi posiłek na {_day?.Date:dd.MM.yyyy}. " +
                $"Pozostało około {Math.Max(0, remaining?.CaloriesKcal ?? 0):0} kcal, " +
                $"B {Math.Max(0, remaining?.ProteinG ?? 0):0} g, " +
                $"T {Math.Max(0, remaining?.FatG ?? 0):0} g i " +
                $"W {Math.Max(0, remaining?.CarbohydratesG ?? 0):0} g. " +
                "Najpierw porozmawiaj ze mną i pokaż propozycję. Niczego nie zapisuj bez mojego zatwierdzenia.";
            return $"/assistant?prompt={Uri.EscapeDataString(prompt)}";
        }
    }
    protected override async Task OnInitializedAsync()
    {
        _user = await Account.GetCurrentUser();
        if (_user is not null) await LoadUserData();
        _loading = false;
    }

    private async Task Login() => await Run(async () =>
    {
        _user = await Account.Login(new LoginRequest(_login.Email, _login.Password));
        await LoadUserData();
        Navigation.NavigateTo("/", forceLoad: true);
    }, "Nie udało się zalogować.");

    private async Task Register() => await Run(async () =>
    {
        _user = await Account.Register(new RegisterRequest(_register.Email, _register.Password, _register.TimeZoneId));
        await LoadUserData();
        Navigation.NavigateTo("/", forceLoad: true);
    }, "Nie udało się utworzyć konta.");

    private async Task LoadUserData()
    {
        _profile = await Account.GetProfile();
        _mealSlots = _profile.MealSlots?.Where(x => !string.IsNullOrWhiteSpace(x)).ToList() ?? _mealSlots;
        _mealSchedule = _profile.MealSchedule?.Where(x => x.Enabled).ToList() ?? [];
        _day = await Nutrition.GetDay(DateOnly.FromDateTime(DateTime.Now));
        foreach (var slot in _mealSlots.Where(slot => MealsFor(slot).Count > 0)) _openMealSlots.Add(slot);
        _todayWorkout = await TrainingApi.GetToday();
        _plans = await TrainingApi.GetPlans();
        _activeSession = await TrainingApi.GetActiveSession();
        var today = DateOnly.FromDateTime(DateTime.Today);
        var offset = (7 + (int)today.DayOfWeek - (int)(_profile?.WeekStartsOn ?? DayOfWeek.Monday)) % 7;
        _consistency = await ProgressApi.GetConsistency(today.AddDays(-offset), today);
    }

    private MealScheduleEntry MealAppearance(string slot) =>
        _mealSchedule.FirstOrDefault(x => x.Name.Equals(slot, StringComparison.OrdinalIgnoreCase))
        ?? new MealScheduleEntry(slot, new TimeOnly(12, 0), true);

    private bool IsMealSlotOpen(string slot) => _openMealSlots.Contains(slot);

    private void ToggleMealSlot(string slot)
    {
        if (!_openMealSlots.Add(slot)) _openMealSlots.Remove(slot);
    }

    private async Task StartWorkout()
    {
        var session = await TrainingApi.Start(_todayWorkout!.TrainingDayId);
        Navigation.NavigateTo($"/workout/{session.Id}");
    }

    private async Task StartSelectedWorkout()
    {
        if (_selectedTrainingDay is not Guid dayId)
            return;

        var session = await TrainingApi.Start(dayId);
        Navigation.NavigateTo($"/workout/{session.Id}");
    }

    private List<MealResponse> MealsFor(string slot) => _day?.Meals.Where(x => BelongsTo(x.Name, slot)).ToList() ?? [];
    private List<MealResponse> UnassignedMeals => _day?.Meals.Where(x => !_mealSlots.Any(slot => BelongsTo(x.Name, slot))).ToList() ?? [];
    private static bool BelongsTo(string mealName, string slot) => mealName.Equals(slot, StringComparison.OrdinalIgnoreCase) || mealName.StartsWith(slot + " · ", StringComparison.OrdinalIgnoreCase);
    private static string DisplayMealName(string mealName, string slot) => mealName.StartsWith(slot + " · ", StringComparison.OrdinalIgnoreCase) ? mealName[(slot.Length + 3)..] : mealName;
    private static string MealEntryUrl(string slot) => $"/food/add?date={DateOnly.FromDateTime(DateTime.Now):yyyy-MM-dd}&slot={Uri.EscapeDataString(slot)}";
    private static string MealEditUrl(Guid id, string? slot)
    {
        var url = $"/food/add?date={DateOnly.FromDateTime(DateTime.Now):yyyy-MM-dd}&edit={id}";
        return string.IsNullOrWhiteSpace(slot) ? url : $"{url}&slot={Uri.EscapeDataString(slot)}";
    }

    private async Task DeleteMeal(Guid id)
    {
        await Run(async () =>
        {
            await Nutrition.DeleteMeal(id);
            _day = await Nutrition.GetDay(DateOnly.FromDateTime(DateTime.Now));
            Snackbar.Add("Pozycja została usunięta.", Severity.Success);
        }, "Nie udało się usunąć pozycji.");
    }

    private async Task Run(Func<Task> action, string error)
    {
        try { await action(); }
        catch (HttpRequestException) { Snackbar.Add(error, Severity.Error); }
    }

    private sealed class LoginForm { public string Email { get; set; } = string.Empty; public string Password { get; set; } = string.Empty; }
    private sealed class RegisterForm { public string Email { get; set; } = string.Empty; public string Password { get; set; } = string.Empty; public string TimeZoneId { get; set; } = "Europe/Warsaw"; }
}
