@page "/progress/achievements"
@inject AccountClient Account
@inject CoachingClient Coaching
@inject NavigationManager Navigation

<PageTitle>Osiągnięcia · FormaAI</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="content-wrap module-page achievements-page">
    <header class="module-heading compact-heading"><MudIconButton Icon="@Icons.Material.Outlined.ArrowBack" Href="/progress" aria-label="Wróć" /><div><span class="page-kicker">Kamienie milowe</span><MudText Typo="Typo.h4">Twoje osiągnięcia</MudText><p>To zapis faktycznych działań, nie punkty za samo otwieranie aplikacji.</p></div></header>
    @if (_loading) { <PageSkeleton Message="Wczytuję osiągnięcia" Compact="true" /> }
    else
    {
        <div class="achievement-list">
            @foreach (var item in _items)
            {
                <article class="achievement-card @(item.EarnedOn.HasValue ? "earned" : "locked")">
                    <div class="achievement-icon"><MudIcon Icon="@Icon(item.Category)" /></div>
                    <div>
                        <span>@item.Category · @(item.EarnedOn?.ToString("dd.MM.yyyy") ?? "do zdobycia")</span>
                        <strong>@item.Title</strong>
                        <p>@(item.EarnedOn.HasValue ? item.Detail : item.Requirement)</p>
                    </div>
                </article>
            }
        </div>
    }
</MudContainer>

@code {
    private IReadOnlyList<AchievementResponse> _items = []; private bool _loading = true;
    protected override async Task OnInitializedAsync() { if (await Account.GetCurrentUser() is null) { Navigation.NavigateTo("/"); return; } _items = await Coaching.GetAchievements(); _loading = false; }
    private static string Icon(string category) => category switch { "Trening" => Icons.Material.Outlined.FitnessCenter, "Jedzenie" => Icons.Material.Outlined.Restaurant, "Sylwetka" => Icons.Material.Outlined.AccessibilityNew, _ => Icons.Material.Outlined.LocalFireDepartment };
}
