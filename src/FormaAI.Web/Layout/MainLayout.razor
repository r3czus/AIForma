@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Class="top-bar">
        <a href="/" class="brand-lockup" aria-label="FormaAI — strona główna">
            <span>FORMA</span><strong>/AI</strong>
        </a>
        <span class="brand-tagline">Ruch · paliwo · rytm</span>
        <MudSpacer />
        <MudButton Href="/assistant" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.AutoAwesome" Class="assistant-link">
            <span class="assistant-label">Zapytaj AI</span>
        </MudButton>
    </MudAppBar>

    <MudMainContent Class="page-content">
        @Body
    </MudMainContent>

    <nav class="bottom-nav" aria-label="Główna nawigacja">
        <NavLink href="/" Match="NavLinkMatch.All">
            <MudIcon Icon="@Icons.Material.Outlined.Today" />
            <span>Dzisiaj</span>
        </NavLink>
        <NavLink href="/food">
            <MudIcon Icon="@Icons.Material.Outlined.RestaurantMenu" />
            <span>Jedzenie</span>
        </NavLink>
        <NavLink href="/progress" class="nav-center-link">
            <span class="nav-center-mark"><MudIcon Icon="@Icons.Material.Outlined.ShowChart" /></span>
            <span>Progres</span>
        </NavLink>
        <NavLink href="/training">
            <MudIcon Icon="@Icons.Material.Outlined.FitnessCenter" />
            <span>Trening</span>
        </NavLink>
        <NavLink href="/profile">
            <MudIcon Icon="@Icons.Material.Outlined.Person" />
            <span>Profil</span>
        </NavLink>
    </nav>
</MudLayout>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#3157E5",
            Secondary = "#5E6B64",
            Tertiary = "#EF884E",
            Background = "#F2F5F1",
            Surface = "#FFFFFF",
            AppbarBackground = "#F2F5F1",
            AppbarText = "#15221C",
            TextPrimary = "#15221C",
            TextSecondary = "#5E6B64",
            Divider = "#D5DED7",
            Success = "#3F9B73",
            Warning = "#D66A28",
            Error = "#C73E32"
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "18px"
        }
    };
}
