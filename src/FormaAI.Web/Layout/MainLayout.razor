@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Class="top-bar">
        <a href="/" class="brand-lockup" aria-label="FormaAI — strona główna">
            <span>FORMA</span><strong>/AI</strong>
        </a>
        <span class="brand-tagline">Ruch · paliwo · rytm</span>
        <MudSpacer />
        <MudButton Href="/assistant" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.AutoAwesome" Class="assistant-link">
            <span class="assistant-label">Asystent AI</span>
        </MudButton>
    </MudAppBar>

    <MudMainContent Class="page-content">
        @Body
    </MudMainContent>

    <nav class="bottom-nav" aria-label="Główna nawigacja">
        <NavLink href="/" Match="NavLinkMatch.All">
            <MudIcon Icon="@Icons.Material.Outlined.Today" />
            <span class="nav-label">Dzisiaj</span>
        </NavLink>
        <NavLink href="/food">
            <MudIcon Icon="@Icons.Material.Outlined.RestaurantMenu" />
            <span class="nav-label">Jedzenie</span>
        </NavLink>
        <NavLink href="/progress">
            <MudIcon Icon="@Icons.Material.Outlined.ShowChart" />
            <span class="nav-label">Progres</span>
        </NavLink>
        <NavLink href="/training">
            <MudIcon Icon="@Icons.Material.Outlined.FitnessCenter" />
            <span class="nav-label">Trening</span>
        </NavLink>
        <NavLink href="/profile">
            <MudIcon Icon="@Icons.Material.Outlined.Person" />
            <span class="nav-label">Profil</span>
        </NavLink>
    </nav>
</MudLayout>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#3451D1",
            Secondary = "#596760",
            Tertiary = "#B9562C",
            Background = "#F4F6F3",
            Surface = "#FFFFFF",
            AppbarBackground = "#F4F6F3",
            AppbarText = "#17211C",
            TextPrimary = "#17211C",
            TextSecondary = "#596760",
            Divider = "#D7DDD8",
            Success = "#287454",
            Warning = "#A94D24",
            Error = "#B93B35"
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "10px"
        }
    };
}
